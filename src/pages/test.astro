---
/**
 * /test - Design prototype page V2
 * Iteration 2: More Framer-like with animated blobs, glassmorphism, dynamic layouts
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Icon from '@/components/ui/Icon.astro';
import FeaturedServiceBanner from '@/components/sections/FeaturedServiceBanner.astro';
import TrustedBy from '@/components/sections/TrustedBy.astro';
import { getCollection } from 'astro:content';

const lang = 'en';

// Fetch blog posts grouped by category
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => post.id.startsWith('en/') && !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const getBlogUrl = (post: typeof posts[0]) => {
  const slug = post.slug.replace(/^(en|fr)\//, '');
  return `/en/blog/${slug}`;
};

// Get 3 latest per category
const categories = ['ai', 'seo', 'paid-ads', 'abm', 'marketing-ops', 'strategy'] as const;
const postsByCategory: Record<string, typeof posts> = {};
for (const cat of categories) {
  postsByCategory[cat] = posts.filter(p => p.data.category === cat).slice(0, 3);
}
// Default: latest 3 across all
postsByCategory['all'] = posts.slice(0, 3);

const categoryLabels: Record<string, string> = {
  'all': 'Latest',
  'ai': 'AI',
  'seo': 'SEO',
  'paid-ads': 'Paid Ads',
  'abm': 'ABM',
  'marketing-ops': 'Marketing Ops',
  'strategy': 'Strategy',
};

const categoryColors: Record<string, string> = {
  'all': 'bg-slate-100 text-slate-700',
  'ai': 'bg-cyan-100 text-cyan-700',
  'seo': 'bg-emerald-100 text-emerald-700',
  'paid-ads': 'bg-amber-100 text-amber-700',
  'abm': 'bg-pink-100 text-pink-700',
  'marketing-ops': 'bg-violet-100 text-violet-700',
  'strategy': 'bg-blue-100 text-blue-700',
};

const formatDate = (date: Date) => date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

// Services
const services = [
  { icon: "search", name: "SEO", description: "Technical optimization, content strategy, and link building that compounds.", link: "/en/services/seo", color: "#10B981" },
  { icon: "trending-up", name: "Google Ads", description: "Search, Display, YouTube & PMax campaigns engineered for ROI.", link: "/en/services/google-ads", color: "#F59E0B" },
  { icon: "users", name: "Paid Social", description: "LinkedIn, Meta, TikTok - precision targeting on every platform.", link: "/en/services/paid-social", color: "#8B5CF6" },
  { icon: "mail", name: "Email Marketing", description: "Automated nurture sequences and campaigns that engage.", link: "/en/services/emailing", color: "#F43F5E" },
  { icon: "cpu", name: "AI Training", description: "Practical workshops to upskill your team on AI and automation.", link: "/en/services/ai-training", color: "#06B6D4" },
  { icon: "settings", name: "AI Solutions", description: "Custom AI agents, workflows and integrations for your business.", link: "/en/services/ai-solutions", color: "#6366F1" },
  { icon: "bar-chart-2", name: "Tracking & Reporting", description: "GA4, GTM, pixel setup and dashboards that drive decisions.", link: "/en/services/tracking-reporting", color: "#14B8A6" },
];

// Testimonials
const testimonials = [
  {
    quote: "We were looking to improve our digital marketing efforts, but had a gap in the marketing team and over 12 internal tools to handle. MyDigipal was able to overcome significant challenges and successfully executed an ABM revamp across LinkedIn. Very impressive.",
    author: "Brett Rieser", role: "Digital Marketing Director EMEA", company: "Genesys",
    image: "https://cdn.prod.website-files.com/64ec8901e801c89308b10a5b/66a8c81987fc1c9e891a99d4_Brett%20Reiser%20100px.webp",
  },
  {
    quote: "From the ground up, MyDigipal's strategic acumen was invaluable. They didn't just consult; they immersed themselves in our mission. Their contributions led to a suite of high-value leads, a significant uptick in conversions.",
    author: "Surbhi Rathore", role: "CEO & Co-founder", company: "Symbl.ai",
    image: "https://cdn.prod.website-files.com/64ec8901e801c89308b10a5b/658bfb59bff3f1c0d42aa4a8_Surbhi%20Rathore.webp",
  },
  {
    quote: "The ABM programs MyDigipal put in place helped Quantum Metrics identify and focus on the most valuable target accounts. We were able to accelerate the deal closing process by 30%!",
    author: "Kelly Wright", role: "Global Marketing Director", company: "Quantum Metric",
    image: "https://cdn.prod.website-files.com/64ec8901e801c89308b10a5b/65705ec9b5160a80c8b72771_Kelly%20Wright.webp",
  },
];
---

<BaseLayout lang={lang} title="Design Prototypes V2" noindex={true}>
  <Header lang={lang} />

  <main class="flex-grow">
    <!-- Nav -->
    <nav class="sticky top-0 z-40 bg-white/80 backdrop-blur-lg border-b border-slate-200/60">
      <div class="container-custom py-3 flex items-center gap-6 overflow-x-auto no-scrollbar text-sm">
        <span class="text-slate-400 font-medium shrink-0">V2:</span>
        <a href="#hero-v2" class="text-slate-600 hover:text-slate-900 transition-colors whitespace-nowrap">Hero</a>
        <a href="#services-v2" class="text-slate-600 hover:text-slate-900 transition-colors whitespace-nowrap">Services</a>
        <a href="#featured-service" class="text-slate-600 hover:text-slate-900 transition-colors whitespace-nowrap">Featured</a>
        <a href="#testimonials-v2" class="text-slate-600 hover:text-slate-900 transition-colors whitespace-nowrap">Testimonials</a>
        <a href="#blog-preview" class="text-slate-600 hover:text-slate-900 transition-colors whitespace-nowrap">Blog</a>
        <a href="#final-cta-v2" class="text-slate-600 hover:text-slate-900 transition-colors whitespace-nowrap">CTA</a>
      </div>
    </nav>


    <!-- =========================================== -->
    <!-- HERO V2 - Animated blobs + glassmorphism -->
    <!-- =========================================== -->
    <section id="hero-v2" class="relative overflow-hidden min-h-[92vh] flex items-center">
      <!-- Base background -->
      <div class="absolute inset-0 bg-[#f8f9fc]"></div>

      <!-- Animated gradient blobs -->
      <div class="hero-blob blob-1"></div>
      <div class="hero-blob blob-2"></div>
      <div class="hero-blob blob-3"></div>

      <!-- Dot grid overlay -->
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #64748b 1px, transparent 1px); background-size: 24px 24px;"></div>

      <div class="relative z-10 container-custom py-24 lg:py-32">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <!-- Left: Text content -->
          <div>
            <!-- Animated badge -->
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/60 backdrop-blur-md border border-white/80 shadow-sm text-sm font-medium text-slate-700 mb-8 hero-animate" style="--delay: 0ms;">
              <span class="w-2 h-2 rounded-full bg-emerald-500 animate-subtle-pulse"></span>
              <span>AI-Powered Digital Marketing Agency</span>
            </div>

            <!-- Headline -->
            <h1 class="font-display text-5xl md:text-6xl lg:text-[4.5rem] font-extrabold text-slate-900 leading-[1.05] tracking-tight mb-6 hero-animate" style="--delay: 100ms;">
              Your growth<br />
              partner in<br />
              <span class="hero-gradient-text">digital marketing</span>
            </h1>

            <!-- Subheadline -->
            <p class="text-xl text-slate-500 mb-10 max-w-lg leading-relaxed hero-animate" style="--delay: 200ms;">
              We're an extension of your team. A truly international agency of passionate marketeers - no fluff, no long SLAs, just results.
            </p>

            <!-- CTAs -->
            <div class="flex flex-wrap gap-4 hero-animate" style="--delay: 300ms;">
              <a href="/en/calculator" class="group inline-flex items-center gap-2.5 px-7 py-4 bg-slate-900 text-white font-semibold rounded-xl hover:bg-slate-800 active:scale-[0.98] transition-all duration-200 shadow-lg shadow-slate-900/20">
                <span>Get your free quote</span>
                <Icon name="arrow-right" size={18} class="group-hover:translate-x-0.5 transition-transform" />
              </a>
              <a href="/en/case-studies" class="inline-flex items-center gap-2 px-7 py-4 bg-white/70 backdrop-blur-sm text-slate-700 font-semibold rounded-xl border border-slate-200 hover:bg-white hover:border-slate-300 transition-all duration-200">
                View case studies
              </a>
            </div>

            <!-- Social proof mini -->
            <div class="flex items-center gap-4 mt-10 hero-animate" style="--delay: 400ms;">
              <div class="flex -space-x-2">
                {testimonials.map(t => (
                  <img src={t.image} alt={t.author} class="w-9 h-9 rounded-full border-2 border-white object-cover" loading="lazy" />
                ))}
              </div>
              <div class="text-sm text-slate-500">
                <span class="font-semibold text-slate-700">50+ clients</span> across 8+ countries
              </div>
            </div>
          </div>

          <!-- Right: Floating glass cards -->
          <div class="relative hidden lg:block h-[500px]">
            <!-- Main glass card -->
            <div class="glass-card absolute top-8 left-8 right-0 p-6 hero-animate" style="--delay: 200ms;">
              <div class="flex items-center gap-3 mb-4">
                <div class="w-10 h-10 rounded-lg bg-emerald-500 flex items-center justify-center">
                  <Icon name="trending-up" size={20} class="text-white" />
                </div>
                <div>
                  <div class="text-sm font-semibold text-slate-900">Organic Traffic</div>
                  <div class="text-xs text-emerald-600">+247% this quarter</div>
                </div>
              </div>
              <div class="flex gap-1 items-end h-16">
                {[35, 42, 38, 55, 48, 62, 58, 72, 68, 85, 78, 95].map((h) => (
                  <div class="flex-1 rounded-sm bg-gradient-to-t from-emerald-500 to-emerald-400" style={`height: ${h}%`}></div>
                ))}
              </div>
            </div>

            <!-- Secondary glass card -->
            <div class="glass-card absolute top-48 -left-4 w-72 p-5 hero-animate" style="--delay: 350ms;">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-9 h-9 rounded-lg bg-violet-500 flex items-center justify-center">
                  <Icon name="target" size={18} class="text-white" />
                </div>
                <div>
                  <div class="text-sm font-semibold text-slate-900">ABM Campaign</div>
                  <div class="text-xs text-slate-500">Pipeline acceleration</div>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <div class="flex-1 h-2 bg-slate-100 rounded-full overflow-hidden">
                  <div class="h-full bg-violet-500 rounded-full" style="width: 78%"></div>
                </div>
                <span class="text-xs font-semibold text-violet-600">78%</span>
              </div>
            </div>

            <!-- Third glass card -->
            <div class="glass-card absolute bottom-8 right-4 w-64 p-5 hero-animate" style="--delay: 500ms;">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-lg bg-amber-500 flex items-center justify-center">
                  <Icon name="zap" size={18} class="text-white" />
                </div>
                <div>
                  <div class="text-sm font-semibold text-slate-900">ROAS</div>
                  <div class="text-2xl font-bold text-amber-600">4.8x</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- TRUSTED BY -->
    <TrustedBy lang={lang} variant="compact" />


    <!-- =========================================== -->
    <!-- SERVICES V2 - Hover cards with color accent -->
    <!-- =========================================== -->
    <section id="services-v2" class="py-24 bg-white">
      <div class="container-custom">
        <div class="text-center mb-14 animate-on-scroll">
          <p class="text-sm font-medium text-indigo-600 tracking-wide mb-3">Our services</p>
          <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-slate-900 tracking-tight mb-4">
            Full-stack digital marketing
          </h2>
          <p class="text-lg text-slate-500 max-w-2xl mx-auto">
            From strategy to execution, we cover every channel your audience uses.
          </p>
        </div>

        <!-- Services: responsive bento-ish grid -->
        <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {services.map((service, index) => (
            <a
              href={service.link}
              class="service-card group relative p-6 rounded-2xl border border-slate-150 bg-white hover:bg-slate-50/50 transition-all duration-300 animate-on-scroll overflow-hidden"
              style={`animation-delay: ${index * 60}ms`}
            >
              <!-- Hover color accent overlay -->
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" style={`background: linear-gradient(135deg, ${service.color}08, ${service.color}03);`}></div>

              <!-- Top bar accent -->
              <div class="absolute top-0 left-6 right-6 h-[2px] rounded-full opacity-0 group-hover:opacity-100 transition-all duration-300" style={`background: ${service.color};`}></div>

              <div class="relative z-10">
                <div class="flex items-center justify-between mb-4">
                  <div class="w-11 h-11 rounded-xl flex items-center justify-center transition-colors duration-300" style={`background: ${service.color}15;`}>
                    <Icon name={service.icon} size={22} class="transition-colors duration-300" />
                  </div>
                  <Icon name="arrow-right" size={16} class="text-slate-300 group-hover:text-slate-500 group-hover:translate-x-1 transition-all duration-200" />
                </div>

                <h3 class="font-display text-lg font-bold text-slate-900 mb-2">{service.name}</h3>
                <p class="text-sm text-slate-500 leading-relaxed">{service.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>


    <!-- FEATURED SERVICE BANNER -->
    <div id="featured-service">
      <FeaturedServiceBanner lang={lang} />
    </div>


    <!-- =========================================== -->
    <!-- TESTIMONIALS V2 -->
    <!-- =========================================== -->
    <section id="testimonials-v2" class="py-24 bg-slate-50">
      <div class="container-custom">
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between mb-14 animate-on-scroll">
          <div>
            <p class="text-sm font-medium text-indigo-600 tracking-wide mb-3">Client feedback</p>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-slate-900 tracking-tight">
              Trusted by marketing leaders
            </h2>
          </div>
          <a href="/en/case-studies" class="group inline-flex items-center gap-2 text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors mt-4 lg:mt-0">
            <span>View all case studies</span>
            <Icon name="arrow-right" size={14} class="group-hover:translate-x-0.5 transition-transform" />
          </a>
        </div>

        <div class="grid lg:grid-cols-5 gap-6">
          <!-- Featured testimonial -->
          <div class="lg:col-span-3 bg-white rounded-2xl p-8 lg:p-10 border border-slate-200 animate-on-scroll">
            <div class="flex gap-1 mb-6">
              {[1,2,3,4,5].map(() => (
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#f59e0b"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              ))}
            </div>
            <blockquote class="text-lg lg:text-xl text-slate-700 leading-relaxed mb-8">"{testimonials[0].quote}"</blockquote>
            <div class="flex items-center gap-4">
              <img src={testimonials[0].image} alt={testimonials[0].author} class="w-12 h-12 rounded-full object-cover" loading="lazy" />
              <div>
                <div class="font-semibold text-slate-900">{testimonials[0].author}</div>
                <div class="text-sm text-slate-500">{testimonials[0].role}, {testimonials[0].company}</div>
              </div>
            </div>
          </div>

          <div class="lg:col-span-2 flex flex-col gap-6">
            {testimonials.slice(1).map((t, i) => (
              <div class="bg-white rounded-2xl p-6 border border-slate-200 flex-1 animate-on-scroll" style={`animation-delay: ${(i+1)*100}ms`}>
                <div class="flex gap-1 mb-4">
                  {[1,2,3,4,5].map(() => (
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="#f59e0b"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  ))}
                </div>
                <blockquote class="text-sm text-slate-600 leading-relaxed mb-5">"{t.quote}"</blockquote>
                <div class="flex items-center gap-3">
                  <img src={t.image} alt={t.author} class="w-10 h-10 rounded-full object-cover" loading="lazy" />
                  <div>
                    <div class="text-sm font-semibold text-slate-900">{t.author}</div>
                    <div class="text-xs text-slate-500">{t.role}, {t.company}</div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>


    <!-- =========================================== -->
    <!-- BLOG PREVIEW - Category filters + 3 cards -->
    <!-- =========================================== -->
    <section id="blog-preview" class="py-24 bg-white">
      <div class="container-custom">
        <div class="text-center mb-10 animate-on-scroll">
          <p class="text-sm font-medium text-indigo-600 tracking-wide mb-3">Insights & Resources</p>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-slate-900 tracking-tight mb-4">
            Latest from our blog
          </h2>
          <p class="text-lg text-slate-500 max-w-2xl mx-auto">
            Expert insights on digital marketing, AI, SEO, and B2B growth strategies.
          </p>
        </div>

        <!-- Category filter tabs -->
        <div class="flex flex-wrap justify-center gap-2 mb-12 animate-on-scroll">
          {Object.entries(categoryLabels).map(([catId, label]) => (
            <button
              class={`blog-filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 border ${catId === 'all' ? 'bg-slate-900 text-white border-slate-900' : 'bg-white text-slate-600 border-slate-200 hover:border-slate-300 hover:bg-slate-50'}`}
              data-category={catId}
            >
              {label}
            </button>
          ))}
        </div>

        <!-- Blog cards container - 3 uniform cards -->
        <div class="blog-cards-container grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
          {Object.entries(postsByCategory).map(([catId, catPosts]) => (
            catPosts.map((post, index) => (
              <a
                href={getBlogUrl(post)}
                class={`blog-card group block rounded-2xl overflow-hidden border border-slate-200 hover:border-slate-300 hover:shadow-medium transition-all duration-300 bg-white ${catId !== 'all' ? 'hidden' : ''}`}
                data-category={catId}
                style={`animation-delay: ${index * 100}ms`}
              >
                <!-- Image -->
                <div class="aspect-[16/10] overflow-hidden bg-slate-100">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
                    loading="lazy"
                  />
                </div>

                <!-- Content -->
                <div class="p-5">
                  <div class="flex items-center gap-2 mb-3">
                    <span class={`px-2.5 py-0.5 text-xs font-medium rounded-md ${categoryColors[post.data.category] || 'bg-slate-100 text-slate-600'}`}>
                      {categoryLabels[post.data.category] || post.data.category}
                    </span>
                    <span class="text-xs text-slate-400">{formatDate(post.data.date)}</span>
                  </div>

                  <h3 class="font-display text-base font-bold text-slate-900 mb-2 group-hover:text-indigo-600 transition-colors leading-snug line-clamp-2">
                    {post.data.title}
                  </h3>

                  <p class="text-sm text-slate-500 line-clamp-2 leading-relaxed">
                    {post.data.description}
                  </p>
                </div>
              </a>
            ))
          ))}
        </div>

        <!-- CTA -->
        <div class="text-center mt-10 animate-on-scroll">
          <a href="/en/blog" class="group inline-flex items-center gap-2 px-6 py-3 text-sm font-semibold text-slate-700 bg-white border border-slate-200 rounded-xl hover:border-slate-300 hover:shadow-soft transition-all duration-200">
            <span>View all articles</span>
            <Icon name="arrow-right" size={16} class="group-hover:translate-x-0.5 transition-transform" />
          </a>
        </div>
      </div>
    </section>


    <!-- =========================================== -->
    <!-- FINAL CTA V2 -->
    <!-- =========================================== -->
    <section id="final-cta-v2" class="py-24 relative overflow-hidden">
      <div class="absolute inset-0 bg-slate-50"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-indigo-100/50 blur-[100px]"></div>

      <div class="container-custom relative z-10">
        <div class="max-w-3xl mx-auto text-center animate-on-scroll">
          <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-slate-900 tracking-tight mb-6">
            Ready to grow your business?
          </h2>
          <p class="text-lg text-slate-500 mb-10 max-w-xl mx-auto">
            Let's discuss how we can help you achieve your marketing goals.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a href="/en/contact" class="group inline-flex items-center gap-2 px-7 py-4 bg-slate-900 text-white font-semibold rounded-xl hover:bg-slate-800 active:scale-[0.98] transition-all duration-200 shadow-lg shadow-slate-900/20">
              <span>Start a Project</span>
              <Icon name="arrow-right" size={18} class="group-hover:translate-x-0.5 transition-transform" />
            </a>
            <a href="/en/calculator" class="inline-flex items-center gap-2 px-7 py-4 bg-white text-slate-600 font-semibold rounded-xl border border-slate-200 hover:border-slate-300 hover:text-slate-900 transition-all duration-200">
              <Icon name="calculator" size={18} />
              <span>Interactive Quote</span>
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer lang={lang} />
</BaseLayout>

<style>
  /* ===== HERO BLOBS ===== */
  .hero-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.5;
    will-change: transform;
  }

  .blob-1 {
    width: 500px;
    height: 500px;
    background: linear-gradient(135deg, #818cf8, #c084fc);
    top: -10%;
    right: 10%;
    animation: blob-move-1 18s ease-in-out infinite;
  }

  .blob-2 {
    width: 400px;
    height: 400px;
    background: linear-gradient(135deg, #38bdf8, #818cf8);
    bottom: 0%;
    left: 5%;
    animation: blob-move-2 22s ease-in-out infinite;
  }

  .blob-3 {
    width: 350px;
    height: 350px;
    background: linear-gradient(135deg, #34d399, #38bdf8);
    top: 30%;
    right: 30%;
    animation: blob-move-3 20s ease-in-out infinite;
  }

  @keyframes blob-move-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(40px, 30px) scale(1.05); }
    66% { transform: translate(-30px, -20px) scale(0.95); }
  }

  @keyframes blob-move-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-30px, -40px) scale(1.08); }
    66% { transform: translate(40px, 20px) scale(0.92); }
  }

  @keyframes blob-move-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(20px, -30px) scale(0.97); }
    66% { transform: translate(-40px, 30px) scale(1.03); }
  }

  /* ===== HERO ANIMATIONS ===== */
  .hero-animate {
    opacity: 0;
    transform: translateY(20px);
    animation: hero-reveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes hero-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ===== GRADIENT TEXT ===== */
  .hero-gradient-text {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ===== GLASS CARDS ===== */
  .glass-card {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.9);
    border-radius: 1rem;
    box-shadow:
      0 4px 24px -4px rgba(0, 0, 0, 0.08),
      0 0 0 1px rgba(255, 255, 255, 0.5) inset;
  }

  /* ===== SERVICE CARDS ===== */
  .service-card {
    border-color: rgb(226 232 240);
  }

  .service-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px -8px rgba(0, 0, 0, 0.1);
  }

  /* ===== LINE CLAMP ===== */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  // Intersection Observer for scroll animations
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    document.querySelectorAll('.animate-on-scroll, .stagger-children').forEach((el) => {
      observer.observe(el);
    });

    // Blog category filter
    const filterBtns = document.querySelectorAll('.blog-filter-btn');
    const blogCards = document.querySelectorAll('.blog-card');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.getAttribute('data-category') || 'all';

        // Update button styles
        filterBtns.forEach(b => {
          b.classList.remove('bg-slate-900', 'text-white', 'border-slate-900');
          b.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
        });
        btn.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');
        btn.classList.add('bg-slate-900', 'text-white', 'border-slate-900');

        // Show/hide cards with animation
        blogCards.forEach(card => {
          const cardCat = card.getAttribute('data-category');
          if (cardCat === cat) {
            card.classList.remove('hidden');
            card.style.opacity = '0';
            card.style.transform = 'translateY(10px)';
            requestAnimationFrame(() => {
              card.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
              card.style.opacity = '1';
              card.style.transform = 'translateY(0)';
            });
          } else {
            card.classList.add('hidden');
          }
        });
      });
    });
  });
</script>
