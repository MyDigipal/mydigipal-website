---
import PageLayout from '@/layouts/PageLayout.astro';
import { type Language, languages } from '@/i18n/config';
import Icon from '@/components/ui/Icon.astro';
import MagneticButton from '@/components/ui/MagneticButton.astro';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Language };

const content = {
  en: {
    pageTitle: 'Thank you - we replied within 24h',
    pageDescription: 'Your message has been sent. Check your spam folder so you don\'t miss our reply.',
    h1: 'Thanks! We\'re on it.',
    intro: 'We\'ve received your message and we\'ll come back to you with a personalised plan within 24h (usually faster).',
    spamHeading: 'Check your spam folder NOW',
    spamLead: 'We just sent you a confirmation email from <strong>paul@mydigipal.com</strong>.',
    spamSub: 'If you don\'t see it within 1 minute:',
    spamStep1: 'Check your <strong>Spam / Promotions / Junk</strong> folder',
    spamStep2: 'Mark it as <strong>"Not spam"</strong> or drag it into your <strong>"Inbox"</strong>',
    spamStep3: 'Add <strong>paul@mydigipal.com</strong> to your contacts',
    spamWhy: 'Otherwise our follow-up emails (including your personalised plan) will land in spam too - and you\'ll miss our proposal.',
    nurtureHeading: 'In the meantime, here\'s what to read',
    cardCaseTitle: 'How Genesys revamped their ABM',
    cardCaseDesc: 'A real story of how we built a global ABM playbook with Genesys, generating +247% pipeline.',
    cardCaseCta: 'Read the case study',
    cardCaseHref: '/en/case-studies/genesys',
    cardMethodTitle: 'Our marketing method',
    cardMethodDesc: 'How we work, what we measure, why our clients stay 18+ months on average.',
    cardMethodCta: 'See how we work',
    cardMethodHref: '/en',
    cardBlogTitle: 'B2B marketing tactics',
    cardBlogDesc: 'Fresh, tested tactics on ABM, paid social, AI workflows. New article every week.',
    cardBlogCta: 'Browse the blog',
    cardBlogHref: '/en/blog',
  },
  fr: {
    pageTitle: 'Merci - on vous a répondu sous 24h',
    pageDescription: 'Votre message est bien reçu. Vérifiez vos spams pour ne pas manquer notre réponse.',
    h1: 'Merci ! On s\'en occupe.',
    intro: 'On a bien reçu votre message et on revient vers vous avec un plan personnalisé sous 24h (souvent plus vite).',
    spamHeading: 'Vérifiez vos spams MAINTENANT',
    spamLead: 'On vient de vous envoyer un email de confirmation depuis <strong>paul@mydigipal.com</strong>.',
    spamSub: 'Si vous ne le voyez pas dans 1 minute :',
    spamStep1: 'Regardez dans votre dossier <strong>Spam / Promotions / Indésirables</strong>',
    spamStep2: 'Marquez-le comme <strong>"non spam"</strong> ou glissez-le dans votre <strong>"Boîte de réception"</strong>',
    spamStep3: 'Ajoutez <strong>paul@mydigipal.com</strong> à vos contacts',
    spamWhy: 'Sinon nos prochains emails (incluant votre plan d\'action personnalisé) iront en spam aussi - et vous raterez notre proposition.',
    nurtureHeading: 'En attendant, voici ce qu\'on vous recommande de lire',
    cardCaseTitle: 'Comment Genesys a refondu son ABM',
    cardCaseDesc: 'L\'histoire vraie de la construction d\'un playbook ABM global avec Genesys. +247% de pipeline.',
    cardCaseCta: 'Lire l\'étude de cas',
    cardCaseHref: '/fr/case-studies/genesys',
    cardMethodTitle: 'Notre méthode marketing',
    cardMethodDesc: 'Comment on travaille, ce qu\'on mesure, pourquoi nos clients restent 18+ mois en moyenne.',
    cardMethodCta: 'Voir comment on travaille',
    cardMethodHref: '/fr',
    cardBlogTitle: 'Tactiques B2B testées',
    cardBlogDesc: 'Tactiques fraiches et testées sur ABM, paid social, workflows IA. 1 article par semaine.',
    cardBlogCta: 'Voir le blog',
    cardBlogHref: '/fr/blog',
  },
};

const t = content[lang];
---

<PageLayout
  lang={lang}
  title={t.pageTitle}
  description={t.pageDescription}
  noindex={true}
>
  <section class="py-16 lg:py-24 bg-gradient-to-b from-white to-slate-50">
    <div class="container-custom max-w-3xl mx-auto">

      <!-- Heading + checkmark animé -->
      <div class="text-center mb-10">
        <div class="merci-check inline-flex items-center justify-center w-20 h-20 rounded-full bg-emerald-100 mb-6">
          <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="merci-check-svg">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
        </div>
        <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 leading-tight mb-4">
          {t.h1}
        </h1>
        <p class="text-lg text-slate-600 max-w-xl mx-auto">
          {t.intro}
        </p>
      </div>

      <!-- ENCART SPAM VIF (impossible à manquer) -->
      <div class="merci-spam-alert relative overflow-hidden rounded-3xl border-4 border-amber-400 bg-gradient-to-br from-amber-50 to-yellow-100 p-6 sm:p-8 mb-12 shadow-xl">
        <div class="absolute -top-2 -right-2 w-24 h-24 bg-amber-400/20 rounded-full blur-2xl"></div>

        <div class="relative flex items-start gap-4">
          <div class="flex-shrink-0 w-12 h-12 sm:w-14 sm:h-14 rounded-2xl bg-amber-500 text-white flex items-center justify-center merci-pulse">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
              <line x1="12" y1="9" x2="12" y2="13"></line>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
          </div>

          <div class="flex-1 min-w-0">
            <h2 class="font-display text-xl sm:text-2xl font-extrabold text-amber-900 mb-3 leading-tight">
              {t.spamHeading}
            </h2>
            <p class="text-base sm:text-lg text-amber-900 mb-3 leading-snug" set:html={t.spamLead} />
            <p class="text-sm sm:text-base font-semibold text-amber-900 mb-3">
              {t.spamSub}
            </p>
            <ol class="space-y-2 text-sm sm:text-base text-amber-900 mb-4 list-decimal list-inside marker:font-bold">
              <li set:html={t.spamStep1} />
              <li set:html={t.spamStep2} />
              <li set:html={t.spamStep3} />
            </ol>
            <p class="text-sm sm:text-base text-amber-800 italic border-t border-amber-300 pt-3">
              {t.spamWhy}
            </p>
          </div>
        </div>
      </div>

      <!-- Nurture cards -->
      <div class="mb-6">
        <h2 class="font-display text-xl sm:text-2xl font-bold text-slate-900 mb-6 text-center">
          {t.nurtureHeading}
        </h2>

        <div class="grid sm:grid-cols-3 gap-4">
          <a href={t.cardCaseHref} class="merci-card group p-5 bg-white rounded-2xl border border-slate-200 hover:border-indigo-400 hover:shadow-lg transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-indigo-100 text-indigo-600 flex items-center justify-center mb-3 group-hover:bg-indigo-500 group-hover:text-white transition-colors">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                <polyline points="14 2 14 8 20 8"></polyline>
              </svg>
            </div>
            <h3 class="font-bold text-slate-900 mb-1 text-sm sm:text-base leading-tight">{t.cardCaseTitle}</h3>
            <p class="text-xs text-slate-600 mb-3 leading-snug">{t.cardCaseDesc}</p>
            <span class="text-xs font-semibold text-indigo-600 inline-flex items-center gap-1">
              {t.cardCaseCta}
              <Icon name="arrow-right" size={12} />
            </span>
          </a>

          <a href={t.cardMethodHref} class="merci-card group p-5 bg-white rounded-2xl border border-slate-200 hover:border-emerald-400 hover:shadow-lg transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-emerald-100 text-emerald-600 flex items-center justify-center mb-3 group-hover:bg-emerald-500 group-hover:text-white transition-colors">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <h3 class="font-bold text-slate-900 mb-1 text-sm sm:text-base leading-tight">{t.cardMethodTitle}</h3>
            <p class="text-xs text-slate-600 mb-3 leading-snug">{t.cardMethodDesc}</p>
            <span class="text-xs font-semibold text-emerald-600 inline-flex items-center gap-1">
              {t.cardMethodCta}
              <Icon name="arrow-right" size={12} />
            </span>
          </a>

          <a href={t.cardBlogHref} class="merci-card group p-5 bg-white rounded-2xl border border-slate-200 hover:border-violet-400 hover:shadow-lg transition-all duration-300">
            <div class="w-10 h-10 rounded-xl bg-violet-100 text-violet-600 flex items-center justify-center mb-3 group-hover:bg-violet-500 group-hover:text-white transition-colors">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 20H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h10l4 4v12a2 2 0 0 1-2 2z"></path>
                <line x1="9" y1="9" x2="10" y2="9"></line>
                <line x1="9" y1="13" x2="15" y2="13"></line>
                <line x1="9" y1="17" x2="15" y2="17"></line>
              </svg>
            </div>
            <h3 class="font-bold text-slate-900 mb-1 text-sm sm:text-base leading-tight">{t.cardBlogTitle}</h3>
            <p class="text-xs text-slate-600 mb-3 leading-snug">{t.cardBlogDesc}</p>
            <span class="text-xs font-semibold text-violet-600 inline-flex items-center gap-1">
              {t.cardBlogCta}
              <Icon name="arrow-right" size={12} />
            </span>
          </a>
        </div>
      </div>

    </div>
  </section>
</PageLayout>

<style>
  /* Checkmark scale-in animation */
  @keyframes mercicheckIn {
    from { transform: scale(0.6); opacity: 0; }
    50% { transform: scale(1.1); }
    to { transform: scale(1); opacity: 1; }
  }
  @keyframes mercicheckDraw {
    from { stroke-dashoffset: 30; }
    to { stroke-dashoffset: 0; }
  }
  .merci-check {
    animation: mercicheckIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .merci-check-svg polyline {
    stroke-dasharray: 30;
    stroke-dashoffset: 30;
    animation: mercicheckDraw 0.5s cubic-bezier(0.4, 0, 0.2, 1) 0.4s forwards;
  }

  /* Pulse on amber alert icon */
  @keyframes merciPulse {
    0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.7); }
    50% { transform: scale(1.05); box-shadow: 0 0 0 12px rgba(245, 158, 11, 0); }
  }
  .merci-pulse {
    animation: merciPulse 2s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .merci-check, .merci-check-svg polyline, .merci-pulse {
      animation: none !important;
    }
    .merci-check { opacity: 1; transform: none; }
    .merci-check-svg polyline { stroke-dashoffset: 0; }
  }
</style>
