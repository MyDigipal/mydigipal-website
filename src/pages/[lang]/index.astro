// Color mappings for services
const colorMap: Record<string, { bg: string; text: string; gradient: string }> = {
  emerald: { bg: "bg-emerald-50", text: "text-emerald-600", gradient: "from-emerald-500 to-teal-600" },
  amber: { bg: "bg-amber-50", text: "text-amber-600", gradient: "from-amber-500 to-orange-600" },
  violet: { bg: "bg-violet-50", text: "text-violet-600", gradient: "from-violet-500 to-purple-600" },
  rose: { bg: "bg-rose-50", text: "text-rose-600", gradient: "from-rose-500 to-pink-600" },
  cyan: { bg: "bg-cyan-50", text: "text-cyan-600", gradient: "from-cyan-500 to-blue-600" },
  indigo: { bg: "bg-indigo-50", text: "text-indigo-600", gradient: "from-indigo-500 to-purple-600" },
  teal: { bg: "bg-teal-50", text: "text-teal-600", gradient: "from-teal-500 to-cyan-600" },
};

const colorHexMap: Record<string, string> = {
  emerald: '#10B981', amber: '#F59E0B', violet: '#8B5CF6',
  rose: '#F43F5E', cyan: '#06B6D4', indigo: '#6366F1', teal: '#14B8A6',
};

// Fetch blog posts
const allPosts = await getCollection('blog');
const blogPosts = allPosts
  .filter((post) => post.id.startsWith(`${lang}/`) && !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const getBlogUrl = (post: typeof blogPosts[0]) => {
  const slug = post.slug.replace(/^(en|fr)\//, '');
  return `/${lang}/blog/${slug}`;
};

const blogCategories = ['all', 'ai', 'seo', 'paid-ads', 'abm', 'marketing-ops', 'strategy'] as const;
const postsByCategory: Record<string, typeof blogPosts> = {};
for (const cat of blogCategories) {
  if (cat === 'all') {
    postsByCategory[cat] = blogPosts.slice(0, 3);
  } else {
    postsByCategory[cat] = blogPosts.filter(p => p.data.category === cat).slice(0, 3);
  }
}

const categoryLabels: Record<string, Record<string, string>> = {
  en: { 'all': 'Latest', 'ai': 'AI', 'seo': 'SEO', 'paid-ads': 'Paid Ads', 'abm': 'ABM', 'marketing-ops': 'Marketing Ops', 'strategy': 'Strategy' },
  fr: { 'all': 'Récents', 'ai': 'IA', 'seo': 'SEO', 'paid-ads': 'Publicité', 'abm': 'ABM', 'marketing-ops': 'Marketing Ops', 'strategy': 'Stratégie' },
};

const categoryColors: Record<string, string> = {
  'all': 'bg-slate-100 text-slate-700',
  'ai': 'bg-cyan-100 text-cyan-700',
  'seo': 'bg-emerald-100 text-emerald-700',
  'paid-ads': 'bg-amber-100 text-amber-700',
  'abm': 'bg-pink-100 text-pink-700',
  'marketing-ops': 'bg-violet-100 text-violet-700',
  'strategy': 'bg-blue-100 text-blue-700',
};

const formatDate = (date: Date) => date.toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-US', { month: 'short', day: 'numeric', year: 'numeric' });

const catLabels = categoryLabels[lang] || categoryLabels.en;
---

<PageLayout lang={lang} description={lang === 'en' ? "AI-powered digital marketing agency for B2B and automotive. SEO, Google Ads, paid social, and ABM from a team that works as an extension of yours." : "Agence marketing digital propulsée par l'IA pour B2B et automobile. SEO, Google Ads, paid social et ABM par une équipe extension de la vôtre."}>
  <!-- ======================== -->
  <!-- HERO SECTION - V2 -->
  <!-- ======================== -->
  <section class="relative overflow-hidden min-h-[92vh] flex items-center">
    <!-- Base background -->
    <div class="absolute inset-0 bg-[#f8f9fc]"></div>

    <!-- Animated gradient blobs -->
    <div class="hero-blob blob-1"></div>
    <div class="hero-blob blob-2"></div>
    <div class="hero-blob blob-3"></div>

    <!-- Dot grid overlay -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #64748b 1px, transparent 1px); background-size: 24px 24px;"></div>

    <div class="relative z-10 container-custom py-24 lg:py-32">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Left: Text content -->
        <div>
          <!-- Animated badge -->
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/60 backdrop-blur-md border border-white/80 shadow-sm text-sm font-medium text-slate-700 mb-8 hero-animate" style="--delay: 0ms;">
            <span class="w-2 h-2 rounded-full bg-emerald-500 animate-subtle-pulse"></span>
            <span>{c.hero.badge}</span>
          </div>

          <!-- Headline -->
          <h1 class="font-display text-5xl md:text-6xl lg:text-[4.5rem] font-extrabold text-slate-900 leading-[1.05] tracking-tight mb-6 hero-animate" style="--delay: 100ms;">
            {lang === 'fr' ? (
              <Fragment>Votre partenaire<br />de croissance en<br /><span class="hero-gradient-text">marketing digital</span></Fragment>
            ) : (
              <Fragment>Your growth<br />partner in<br /><span class="hero-gradient-text">digital marketing</span></Fragment>
            )}
          </h1>

          <!-- Description -->
          <p class="text-xl text-slate-500 mb-10 max-w-lg leading-relaxed hero-animate" style="--delay: 200ms;">
            {c.hero.description}
          </p>

          <!-- CTAs -->
          <div class="flex flex-wrap gap-4 hero-animate" style="--delay: 300ms;">
            <a
              href={`/${lang}/calculator`}
              class="group inline-flex items-center gap-2.5 px-7 py-4 bg-slate-900 text-white font-semibold rounded-xl hover:bg-slate-800 active:scale-[0.98] transition-all duration-200 shadow-lg shadow-slate-900/20"
            >
              <span>{c.hero.cta1}</span>
              <Icon name="arrow-right" size={18} class="group-hover:translate-x-0.5 transition-transform" />
            </a>
            <a
              href={`/${lang}/case-studies`}
              class="inline-flex items-center gap-2 px-7 py-4 bg-white/70 backdrop-blur-sm text-slate-700 font-semibold rounded-xl border border-slate-200 hover:bg-white hover:border-slate-300 transition-all duration-200"
            >
              {c.hero.cta2}
            </a>
          </div>

          <!-- Social proof mini -->
          <div class="flex items-center gap-4 mt-10 hero-animate" style="--delay: 400ms;">
            <div class="flex -space-x-2">
              {testimonials.map(testimonial => (
                <img src={testimonial.image} alt={testimonial.author} class="w-9 h-9 rounded-full border-2 border-white object-cover" loading="lazy" />
              ))}
            </div>
            <div class="text-sm text-slate-500">
              <span class="font-semibold text-slate-700">50+ clients</span> {c.socialProof}
            </div>
          </div>
        </div>

        <!-- Right: Floating glass cards -->
        <div class="relative hidden lg:block h-[500px]">
          <!-- Main glass card - Organic Traffic -->
          <div class="glass-card absolute top-8 left-8 right-0 p-6 hero-animate" style="--delay: 200ms;">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-emerald-500 flex items-center justify-center">
                <Icon name="trending-up" size={20} class="text-white" />
              </div>
              <div>
                <div class="text-sm font-semibold text-slate-900">Organic Traffic</div>
                <div class="text-xs text-emerald-600">+247% this quarter</div>
              </div>
            </div>
            <div class="flex gap-1 items-end h-16">
              {[35, 42, 38, 55, 48, 62, 58, 72, 68, 85, 78, 95].map((h) => (
                <div class="flex-1 rounded-sm bg-gradient-to-t from-emerald-500 to-emerald-400" style={`height: ${h}%`}></div>
              ))}
            </div>
          </div>

          <!-- Secondary glass card - ABM Campaign -->
          <div class="glass-card absolute top-48 -left-4 w-72 p-5 hero-animate" style="--delay: 350ms;">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-9 h-9 rounded-lg bg-violet-500 flex items-center justify-center">
                <Icon name="target" size={18} class="text-white" />
              </div>
              <div>
                <div class="text-sm font-semibold text-slate-900">ABM Campaign</div>
                <div class="text-xs text-slate-500">Pipeline acceleration</div>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <div class="flex-1 h-2 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-full bg-violet-500 rounded-full" style="width: 78%"></div>
              </div>
              <span class="text-xs font-semibold text-violet-600">78%</span>
            </div>
          </div>

          <!-- Third glass card - ROAS -->
          <div class="glass-card absolute bottom-8 right-4 w-64 p-5 hero-animate" style="--delay: 500ms;">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-lg bg-amber-500 flex items-center justify-center">
                <Icon name="zap" size={18} class="text-white" />
              </div>
              <div>
                <div class="text-sm font-semibold text-slate-900">ROAS</div>
