<style>
  /* ===== HERO BLOBS ===== */
  .hero-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.5;
    will-change: transform;
  }

  .blob-1 {
    width: 500px;
    height: 500px;
    background: linear-gradient(135deg, #818cf8, #c084fc);
    top: -10%;
    right: 10%;
    animation: blob-move-1 18s ease-in-out infinite;
  }

  .blob-2 {
    width: 400px;
    height: 400px;
    background: linear-gradient(135deg, #38bdf8, #818cf8);
    bottom: 0%;
    left: 5%;
    animation: blob-move-2 22s ease-in-out infinite;
  }

  .blob-3 {
    width: 350px;
    height: 350px;
    background: linear-gradient(135deg, #34d399, #38bdf8);
    top: 30%;
    right: 30%;
    animation: blob-move-3 20s ease-in-out infinite;
  }

  @keyframes blob-move-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(40px, 30px) scale(1.05); }
    66% { transform: translate(-30px, -20px) scale(0.95); }
  }

  @keyframes blob-move-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-30px, -40px) scale(1.08); }
    66% { transform: translate(40px, 20px) scale(0.92); }
  }

  @keyframes blob-move-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(20px, -30px) scale(0.97); }
    66% { transform: translate(-40px, 30px) scale(1.03); }
  }

  /* ===== HERO ANIMATIONS ===== */
  .hero-animate {
    opacity: 0;
    transform: translateY(20px);
    animation: hero-reveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes hero-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ===== GRADIENT TEXT ===== */
  .hero-gradient-text {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ===== GLASS CARDS ===== */
  .glass-card {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.9);
    border-radius: 1rem;
    box-shadow:
      0 4px 24px -4px rgba(0, 0, 0, 0.08),
      0 0 0 1px rgba(255, 255, 255, 0.5) inset;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .glass-card:hover {
    transform: translateY(-4px) scale(1.015);
    box-shadow:
      0 12px 40px -8px rgba(0, 0, 0, 0.14),
      0 0 0 1px rgba(255, 255, 255, 0.6) inset;
    z-index: 5;
  }

  /* ===== HERO FLOATING CARDS - bob animation ===== */
  .hero-floating-1,
  .hero-floating-2,
  .hero-floating-3 {
    animation: heroFloat 7s ease-in-out infinite;
    will-change: transform;
  }
  .hero-floating-1 { animation-delay: 0s; }
  .hero-floating-2 { animation-delay: -2.3s; animation-duration: 6.5s; }
  .hero-floating-3 { animation-delay: -4.5s; animation-duration: 8s; }

  @keyframes heroFloat {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(2px, -8px) rotate(0.3deg); }
    50% { transform: translate(-2px, -4px) rotate(-0.2deg); }
    75% { transform: translate(3px, -10px) rotate(0.4deg); }
  }

  .glass-card:hover.hero-floating-1,
  .glass-card:hover.hero-floating-2,
  .glass-card:hover.hero-floating-3 {
    /* pause floating on hover, hover elevates instead */
    animation-play-state: paused;
  }

  /* ===== HERO AI CO-PILOT CARD ===== */
  .hero-ai-avatar {
    position: relative;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 60%, #06b6d4 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }
  .hero-ai-pulse {
    position: absolute;
    inset: -4px;
    border-radius: 14px;
    background: linear-gradient(135deg, #6366f1, #06b6d4);
    opacity: 0.4;
    z-index: 0;
    animation: heroAiPulse 2.5s ease-in-out infinite;
  }
  @keyframes heroAiPulse {
    0%, 100% { transform: scale(1); opacity: 0.35; }
    50% { transform: scale(1.15); opacity: 0.15; }
  }

  .hero-status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #10b981;
    box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.2);
    animation: heroStatusPulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes heroStatusPulse {
    0%, 100% { box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.2); }
    50% { box-shadow: 0 0 0 6px rgba(16, 185, 129, 0.05); }
  }

  .hero-tasks-window {
    background: rgba(15, 23, 42, 0.04);
    border: 1px solid rgba(15, 23, 42, 0.06);
    border-radius: 10px;
    padding: 4px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .hero-task {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 10px;
    border-radius: 6px;
    font-size: 12px;
    transition: background 0.3s, opacity 0.4s;
  }
  .hero-task.is-running {
    background: rgba(255, 255, 255, 0.7);
    opacity: 1;
    box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06);
  }
  .hero-task:not(.is-running) {
    opacity: 0.45;
  }
  .hero-task-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .hero-task.is-running .hero-task-dot {
    box-shadow: 0 0 8px currentColor;
    animation: heroTaskDotPulse 1.5s ease-in-out infinite;
  }
  @keyframes heroTaskDotPulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.4); }
  }
  .hero-task-label {
    flex: 1;
    color: rgb(15 23 42);
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .hero-task-status {
    font-size: 9px;
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgb(100 116 139);
  }
  .hero-task.is-running .hero-task-status {
    color: rgb(16 185 129);
  }

  /* ===== HERO MULTI-CHANNEL CARD ===== */
  .hero-channel-bar {
    height: 0%;
    transform-origin: bottom;
    animation: heroChannelGrow 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--bar-i, 0) * 80ms + 700ms);
    transition: filter 0.3s, transform 0.3s;
  }
  .group:hover .hero-channel-bar {
    filter: brightness(1.1);
    transform: scaleY(1.05);
  }
  @keyframes heroChannelGrow {
    from { height: 0%; opacity: 0.3; }
    to { height: var(--bar-h, 50%); opacity: 1; }
  }

  .hero-trending {
    padding: 4px 8px;
    border-radius: 9999px;
    background: rgba(16, 185, 129, 0.12);
  }

  /* ===== HERO ROTATING KPI CARD ===== */
  .hero-kpi-window {
    position: relative;
    height: 60px;
    margin-top: 8px;
  }
  .hero-kpi {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    gap: 12px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }
  .hero-kpi.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .hero-kpi-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .hero-kpi-dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 14px;
  }
  .hero-kpi-dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: rgb(203 213 225);
    transition: width 0.3s, background 0.3s;
    cursor: pointer;
  }
  .hero-kpi-dot.is-active {
    width: 18px;
    background: rgb(99 102 241);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-floating-1,
    .hero-floating-2,
    .hero-floating-3,
    .hero-ai-pulse,
    .hero-status-dot,
    .glass-card {
      animation: none !important;
      transition: none !important;
    }
    .hero-channel-bar {
      animation: none !important;
      height: var(--bar-h, 50%);
    }
    .hero-kpi {
      transition: none !important;
    }
  }

  /* ===== SERVICE CARDS ===== */
  .service-card {
    border-color: rgb(226 232 240);
  }

  .service-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px -8px rgba(0, 0, 0, 0.1);
  }

  /* ===== LINE CLAMP ===== */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .animation-delay-150 { animation-delay: 150ms; }
</style>

<script>
  // Hero AI tasks rotation: highlight one task at a time, cycle every 2.5s
  const wireHeroTasks = () => {
    const containers = document.querySelectorAll<HTMLElement>('[data-hero-tasks]');
    if (!containers.length) return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    containers.forEach((c) => {
      if (c.dataset.heroTasksWired === 'true') return;
      c.dataset.heroTasksWired = 'true';

      const tasks = Array.from(c.querySelectorAll<HTMLElement>('.hero-task'));
      if (!tasks.length) return;

      let idx = 0;
      const setActive = (i: number) => {
        tasks.forEach((t, j) => {
          t.classList.toggle('is-running', j === i);
          const status = t.querySelector('.hero-task-status');
          if (status) status.textContent = j === i ? 'running' : (j < i ? 'done' : 'queued');
        });
      };
      setActive(0);

      if (reduce) return;

      const interval = setInterval(() => {
        idx = (idx + 1) % tasks.length;
        setActive(idx);
      }, 2200);

      // Clean up on page transitions to avoid duplicate intervals
      const cleanup = () => {
        clearInterval(interval);
        document.removeEventListener('astro:before-swap', cleanup);
      };
      document.addEventListener('astro:before-swap', cleanup);
    });
  };

  // Hero KPI rotation: cycle through ROAS / Pipeline / Organic every 3.5s
  const wireHeroKpis = () => {
    const containers = document.querySelectorAll<HTMLElement>('[data-hero-kpis]');
    if (!containers.length) return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    containers.forEach((c) => {
      if (c.dataset.heroKpisWired === 'true') return;
      c.dataset.heroKpisWired = 'true';

      const kpis = Array.from(c.querySelectorAll<HTMLElement>('.hero-kpi'));
      const dots = Array.from(c.parentElement?.querySelectorAll<HTMLElement>('.hero-kpi-dot') || []);
      if (!kpis.length) return;

      let idx = 0;
      const setActive = (i: number) => {
        kpis.forEach((k, j) => k.classList.toggle('is-active', j === i));
        dots.forEach((d, j) => d.classList.toggle('is-active', j === i));
      };
      setActive(0);

      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          idx = i;
          setActive(idx);
        });
      });

      if (reduce) return;

      const interval = setInterval(() => {
        idx = (idx + 1) % kpis.length;
        setActive(idx);
      }, 3200);

      const cleanup = () => {
        clearInterval(interval);
        document.removeEventListener('astro:before-swap', cleanup);
      };
      document.addEventListener('astro:before-swap', cleanup);
    });
  };

  wireHeroTasks();
  wireHeroKpis();
  document.addEventListener('astro:page-load', () => {
    wireHeroTasks();
    wireHeroKpis();
  });
</script>

<script>
  // Blog category filter
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.blog-filter-btn');
    const blogCards = document.querySelectorAll('.blog-card');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.getAttribute('data-category') || 'all';

        // Update button styles
        filterBtns.forEach(b => {
          b.classList.remove('bg-slate-900', 'text-white', 'border-slate-900');
          b.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
        });
        btn.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');
        btn.classList.add('bg-slate-900', 'text-white', 'border-slate-900');

        // Show/hide cards with animation
        blogCards.forEach(card => {
          const cardCat = card.getAttribute('data-category');
          if (cardCat === cat) {
            card.classList.remove('hidden');
            (card as HTMLElement).style.opacity = '0';
            (card as HTMLElement).style.transform = 'translateY(10px)';
            requestAnimationFrame(() => {
              (card as HTMLElement).style.transition = 'opacity 0.3s ease, transform 0.3s ease';
              (card as HTMLElement).style.opacity = '1';
              (card as HTMLElement).style.transform = 'translateY(0)';
            });
          } else {
            card.classList.add('hidden');
          }
        });
      });
    });
  });
</script>
