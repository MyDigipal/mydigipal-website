<style>
  /* ===== HERO BLOBS ===== */
  .hero-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.5;
    will-change: transform;
  }

  .blob-1 {
    width: 500px;
    height: 500px;
    background: linear-gradient(135deg, #818cf8, #c084fc);
    top: -10%;
    right: 10%;
    animation: blob-move-1 18s ease-in-out infinite;
  }

  .blob-2 {
    width: 400px;
    height: 400px;
    background: linear-gradient(135deg, #38bdf8, #818cf8);
    bottom: 0%;
    left: 5%;
    animation: blob-move-2 22s ease-in-out infinite;
  }

  .blob-3 {
    width: 350px;
    height: 350px;
    background: linear-gradient(135deg, #34d399, #38bdf8);
    top: 30%;
    right: 30%;
    animation: blob-move-3 20s ease-in-out infinite;
  }

  @keyframes blob-move-1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(40px, 30px) scale(1.05); }
    66% { transform: translate(-30px, -20px) scale(0.95); }
  }

  @keyframes blob-move-2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(-30px, -40px) scale(1.08); }
    66% { transform: translate(40px, 20px) scale(0.92); }
  }

  @keyframes blob-move-3 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(20px, -30px) scale(0.97); }
    66% { transform: translate(-40px, 30px) scale(1.03); }
  }

  /* ===== HERO ANIMATIONS ===== */
  .hero-animate {
    opacity: 0;
    transform: translateY(20px);
    animation: hero-reveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes hero-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ===== GRADIENT TEXT ===== */
  .hero-gradient-text {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #06b6d4 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ===== GLASS CARDS ===== */
  .glass-card {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.9);
    border-radius: 1rem;
    box-shadow:
      0 4px 24px -4px rgba(0, 0, 0, 0.08),
      0 0 0 1px rgba(255, 255, 255, 0.5) inset;
  }

  /* ===== SERVICE CARDS ===== */
  .service-card {
    border-color: rgb(226 232 240);
  }

  .service-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px -8px rgba(0, 0, 0, 0.1);
  }

  /* ===== LINE CLAMP ===== */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .animation-delay-150 { animation-delay: 150ms; }
</style>

<script>
  // Blog category filter
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.blog-filter-btn');
    const blogCards = document.querySelectorAll('.blog-card');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.getAttribute('data-category') || 'all';

        // Update button styles
        filterBtns.forEach(b => {
          b.classList.remove('bg-slate-900', 'text-white', 'border-slate-900');
          b.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
        });
        btn.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');
        btn.classList.add('bg-slate-900', 'text-white', 'border-slate-900');

        // Show/hide cards with animation
        blogCards.forEach(card => {
          const cardCat = card.getAttribute('data-category');
          if (cardCat === cat) {
            card.classList.remove('hidden');
            (card as HTMLElement).style.opacity = '0';
            (card as HTMLElement).style.transform = 'translateY(10px)';
            requestAnimationFrame(() => {
              (card as HTMLElement).style.transition = 'opacity 0.3s ease, transform 0.3s ease';
              (card as HTMLElement).style.opacity = '1';
              (card as HTMLElement).style.transform = 'translateY(0)';
            });
          } else {
            card.classList.add('hidden');
          }
        });
      });
    });
  });
</script>
