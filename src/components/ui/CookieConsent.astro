---
import type { Language } from '@/i18n/config';

interface Props {
  lang?: Language;
}

const { lang = 'en' } = Astro.props;

const text = lang === 'fr' ? {
  notice: 'Ce site utilise des cookies pour analyser le trafic.',
  ok: 'OK',
  refuse: 'Refuser',
  customize: 'Personnaliser',
  save: 'Enregistrer',
  necessary: 'Essentiels',
  necessaryDesc: 'Requis pour le fonctionnement du site.',
  analytics: 'Analytiques',
  analyticsDesc: 'Comprendre comment les visiteurs utilisent le site.',
  marketing: 'Marketing',
  marketingDesc: 'Mesurer la performance des campagnes publicitaires.',
  privacyPolicy: 'Politique de confidentialit\u00e9',
} : {
  notice: 'This site uses cookies to analyze traffic.',
  ok: 'OK',
  refuse: 'Refuse',
  customize: 'Customize',
  save: 'Save',
  necessary: 'Essential',
  necessaryDesc: 'Required for the website to function.',
  analytics: 'Analytics',
  analyticsDesc: 'Understand how visitors use the site.',
  marketing: 'Marketing',
  marketingDesc: 'Measure advertising campaign performance.',
  privacyPolicy: 'Privacy Policy',
};
---

<!-- Cookie Consent - Slim Bar -->
<div
  id="cookie-consent-banner"
  class="fixed bottom-0 left-0 right-0 z-50 transform translate-y-full transition-transform duration-300 ease-out"
  role="dialog"
  aria-modal="true"
  aria-label={lang === 'fr' ? 'Consentement cookies' : 'Cookie consent'}
>
  <!-- Main slim bar -->
  <div id="cookie-main-view" class="bg-slate-900/95 backdrop-blur-sm border-t border-slate-700/50">
    <div class="max-w-6xl mx-auto px-4 py-3 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-slate-300 text-sm text-center sm:text-left">
        {text.notice}
        <button
          type="button"
          id="cookie-customize-btn"
          class="text-primary-400 hover:text-primary-300 underline underline-offset-2 text-sm bg-transparent border-none cursor-pointer font-inherit ml-1"
        >
          {text.customize}
        </button>
      </p>
      <div class="flex items-center gap-2 shrink-0">
        <button
          type="button"
          id="cookie-reject-btn"
          class="px-4 py-1.5 text-sm font-medium text-slate-400 hover:text-white border border-slate-600 hover:border-slate-500 rounded-lg transition-colors duration-200 bg-transparent cursor-pointer"
        >
          {text.refuse}
        </button>
        <button
          type="button"
          id="cookie-accept-btn"
          class="px-5 py-1.5 text-sm font-medium text-white bg-primary-500 hover:bg-primary-600 rounded-lg transition-colors duration-200 cursor-pointer border-none"
        >
          {text.ok}
        </button>
      </div>
    </div>
  </div>

  <!-- Customize panel (hidden by default) -->
  <div id="cookie-customize-view" class="hidden bg-white border-t border-slate-200 shadow-lg">
    <div class="max-w-2xl mx-auto px-4 py-5">
      <div class="space-y-3">
        <!-- Necessary -->
        <div class="flex items-center justify-between gap-4 py-2">
          <div>
            <span class="font-medium text-slate-900 text-sm">{text.necessary}</span>
            <span class="ml-2 px-1.5 py-0.5 text-[10px] font-medium bg-slate-200 text-slate-500 rounded">
              {lang === 'fr' ? 'Toujours actif' : 'Always on'}
            </span>
            <p class="text-xs text-slate-500 mt-0.5">{text.necessaryDesc}</p>
          </div>
          <div class="w-10 h-5 bg-primary-500 rounded-full relative opacity-60 cursor-not-allowed shrink-0">
            <div class="absolute right-0.5 top-0.5 w-4 h-4 bg-white rounded-full shadow-sm"></div>
          </div>
        </div>
        <!-- Analytics -->
        <div class="flex items-center justify-between gap-4 py-2 border-t border-slate-100">
          <div>
            <span class="font-medium text-slate-900 text-sm">{text.analytics}</span>
            <p class="text-xs text-slate-500 mt-0.5">{text.analyticsDesc}</p>
          </div>
          <label class="relative inline-flex cursor-pointer shrink-0">
            <input type="checkbox" id="cookie-analytics" class="sr-only peer" checked>
            <div class="w-10 h-5 bg-slate-300 rounded-full peer peer-checked:bg-primary-500 transition-colors duration-200">
              <div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white rounded-full shadow-sm transition-transform duration-200 peer-checked:translate-x-5"></div>
            </div>
          </label>
        </div>
        <!-- Marketing -->
        <div class="flex items-center justify-between gap-4 py-2 border-t border-slate-100">
          <div>
            <span class="font-medium text-slate-900 text-sm">{text.marketing}</span>
            <p class="text-xs text-slate-500 mt-0.5">{text.marketingDesc}</p>
          </div>
          <label class="relative inline-flex cursor-pointer shrink-0">
            <input type="checkbox" id="cookie-marketing" class="sr-only peer">
            <div class="w-10 h-5 bg-slate-300 rounded-full peer peer-checked:bg-primary-500 transition-colors duration-200">
              <div class="absolute left-0.5 top-0.5 w-4 h-4 bg-white rounded-full shadow-sm transition-transform duration-200 peer-checked:translate-x-5"></div>
            </div>
          </label>
        </div>
      </div>
      <div class="flex items-center justify-between mt-4 pt-3 border-t border-slate-200">
        <a
          href={`/${lang}/privacy-policy`}
          class="text-xs text-primary-500 hover:underline"
        >
          {text.privacyPolicy}
        </a>
        <button
          type="button"
          id="cookie-save-btn"
          class="px-5 py-1.5 text-sm font-medium text-white bg-primary-500 hover:bg-primary-600 rounded-lg transition-colors duration-200 cursor-pointer border-none"
        >
          {text.save}
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .peer:checked ~ div > div {
    transform: translateX(1.25rem);
  }
</style>

<script is:inline>
(function() {
  var CONSENT_COOKIE = 'mydigipal_consent';
  var CONSENT_VERSION = '1';

  function getConsent() {
    try {
      var cookie = document.cookie.split('; ').find(function(row) { return row.startsWith(CONSENT_COOKIE + '='); });
      if (cookie) return JSON.parse(decodeURIComponent(cookie.split('=')[1]));
    } catch (e) {}
    return null;
  }

  function saveConsent(consent) {
    var expires = new Date();
    expires.setFullYear(expires.getFullYear() + 1);
    document.cookie = CONSENT_COOKIE + '=' + encodeURIComponent(JSON.stringify(consent)) + '; expires=' + expires.toUTCString() + '; path=/; SameSite=Lax';
  }

  function updateConsentMode(consent) {
    window.dataLayer = window.dataLayer || [];
    if (typeof window.gtag === 'function') {
      window.gtag('consent', 'update', {
        'analytics_storage': consent.analytics ? 'granted' : 'denied',
        'ad_storage': consent.marketing ? 'granted' : 'denied',
        'ad_user_data': consent.marketing ? 'granted' : 'denied',
        'ad_personalization': consent.marketing ? 'granted' : 'denied',
      });
    } else {
      window.dataLayer.push('consent', 'update', {
        'analytics_storage': consent.analytics ? 'granted' : 'denied',
        'ad_storage': consent.marketing ? 'granted' : 'denied',
        'ad_user_data': consent.marketing ? 'granted' : 'denied',
        'ad_personalization': consent.marketing ? 'granted' : 'denied',
      });
    }
    window.dataLayer.push({
      'event': 'consent_update',
      'consent_analytics': consent.analytics ? 'granted' : 'denied',
      'consent_marketing': consent.marketing ? 'granted' : 'denied'
    });
    window.dispatchEvent(new CustomEvent('consentUpdated', { detail: consent }));
  }

  function showBanner() {
    var banner = document.getElementById('cookie-consent-banner');
    if (banner) { banner.classList.remove('translate-y-full'); banner.classList.add('translate-y-0'); }
  }

  function hideBanner() {
    var banner = document.getElementById('cookie-consent-banner');
    if (banner) { banner.classList.remove('translate-y-0'); banner.classList.add('translate-y-full'); }
  }

  function showCustomize() {
    document.getElementById('cookie-main-view').classList.add('hidden');
    document.getElementById('cookie-customize-view').classList.remove('hidden');
  }

  function showMain() {
    document.getElementById('cookie-main-view').classList.remove('hidden');
    document.getElementById('cookie-customize-view').classList.add('hidden');
  }

  function handleConsent(type) {
    var consent = { version: CONSENT_VERSION, timestamp: Date.now(), refused: false };
    if (type === 'accept') {
      consent.analytics = true;
      consent.marketing = true;
    } else if (type === 'reject') {
      consent.analytics = false;
      consent.marketing = false;
      consent.refused = true;
    } else if (type === 'save') {
      var analyticsEl = document.getElementById('cookie-analytics');
      var marketingEl = document.getElementById('cookie-marketing');
      consent.analytics = analyticsEl ? analyticsEl.checked : false;
      consent.marketing = marketingEl ? marketingEl.checked : false;
    }
    saveConsent(consent);
    updateConsentMode(consent);
    hideBanner();
  }

  function init() {
    var banner = document.getElementById('cookie-consent-banner');
    if (!banner) return;

    var consent = getConsent();
    if (!consent || consent.version !== CONSENT_VERSION) {
      setTimeout(showBanner, 1500);
    } else {
      updateConsentMode(consent);
    }

    var acceptBtn = document.getElementById('cookie-accept-btn');
    var rejectBtn = document.getElementById('cookie-reject-btn');
    var saveBtn = document.getElementById('cookie-save-btn');
    var customizeBtn = document.getElementById('cookie-customize-btn');

    if (acceptBtn) acceptBtn.addEventListener('click', function() { handleConsent('accept'); });
    if (rejectBtn) rejectBtn.addEventListener('click', function() { handleConsent('reject'); });
    if (saveBtn) saveBtn.addEventListener('click', function() { handleConsent('save'); });
    if (customizeBtn) customizeBtn.addEventListener('click', showCustomize);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  window.openCookieSettings = function() {
    showMain();
    showBanner();
  };
})();
</script>
