---
import { type Language } from '@/i18n/config';
import { t } from '@/i18n/utils';
import Icon from '@/components/ui/Icon.astro';

interface Metric {
  value: string;
  label: string;
}

interface HeroTestimonial {
  quote: string;
  author: string;
  role?: string;
  company?: string;
}

interface Props {
  lang: Language;
  badge?: string;
  headline: string;
  subheadline?: string;
  description: string;
  color?: 'seo' | 'ads' | 'social' | 'abm' | 'training' | 'emailing' | 'ai' | 'tracking' | 'content' | 'primary' | 'automotive';
  /** 2-4 key result metrics surfaced above the fold (proof). */
  metrics?: Metric[];
  /** Scannable "what you get" bullets (typically service feature titles). */
  proofPoints?: string[];
  /** Optional one-line social proof shown in the proof panel footer. */
  testimonial?: HeroTestimonial;
  /** Optional per-page override of the "Trusted by" logo strip. */
  heroLogos?: { name: string; logo: string }[];
}

const {
  lang,
  badge,
  headline,
  subheadline,
  description,
  color = 'primary',
  metrics = [],
  proofPoints = [],
  testimonial,
  heroLogos: heroLogosProp,
} = Astro.props;

const colorConfig = {
  seo: { gradient: 'from-emerald-500 to-teal-600', accent: 'text-emerald-400', ring: 'ring-emerald-500/30' },
  ads: { gradient: 'from-amber-500 to-orange-600', accent: 'text-amber-400', ring: 'ring-amber-500/30' },
  social: { gradient: 'from-violet-500 to-purple-600', accent: 'text-violet-400', ring: 'ring-violet-500/30' },
  abm: { gradient: 'from-pink-500 to-rose-600', accent: 'text-pink-400', ring: 'ring-pink-500/30' },
  training: { gradient: 'from-cyan-500 to-blue-600', accent: 'text-cyan-400', ring: 'ring-cyan-500/30' },
  emailing: { gradient: 'from-rose-500 to-pink-600', accent: 'text-rose-400', ring: 'ring-rose-500/30' },
  ai: { gradient: 'from-indigo-500 to-purple-600', accent: 'text-indigo-400', ring: 'ring-indigo-500/30' },
  tracking: { gradient: 'from-teal-500 to-cyan-600', accent: 'text-teal-400', ring: 'ring-teal-500/30' },
  content: { gradient: 'from-violet-500 to-purple-600', accent: 'text-violet-400', ring: 'ring-violet-500/30' },
  primary: { gradient: 'from-blue-500 to-indigo-600', accent: 'text-blue-400', ring: 'ring-blue-500/30' },
  automotive: { gradient: 'from-sky-500 to-blue-600', accent: 'text-sky-400', ring: 'ring-sky-500/30' },
};

const colors = colorConfig[color];

// Compact, dark-safe client logo strip (white pills) for instant credibility.
// Defaults to the acquisition clients; a page can override with its own set
// (e.g. AI Training passes its training clients).
const defaultHeroLogos = [
  { name: 'Genesys', logo: '/images/Client logo/genesys-vector-logo.png' },
  { name: 'Quantum Metrics', logo: '/images/Client logo/quantum.png' },
  { name: 'OpenText', logo: '/images/Client logo/opentext-logo.png' },
  { name: 'GWI', logo: '/images/Client logo/GWI.webp' },
  { name: 'BYmyCAR', logo: '/images/Client logo/BYmyCAR.png' },
];
const heroLogos = (heroLogosProp && heroLogosProp.length > 0) ? heroLogosProp : defaultHeroLogos;

const labels = {
  en: { trusted: 'Trusted by', results: 'Real results', whatYouGet: 'What you get', and: 'and' },
  fr: { trusted: 'Ils nous font confiance', results: 'Résultats concrets', whatYouGet: 'Ce que vous obtenez', and: 'et' },
};
const lbl = labels[lang] || labels.en;

const showPanel = metrics.length > 0 || proofPoints.length > 0;
---

<section class="hero-section relative flex items-center overflow-hidden bg-slate-950 min-h-[88vh] lg:min-h-screen">
  <!-- Animated Background with Parallax -->
  <div class="absolute inset-0 pointer-events-none">
    <div class={`parallax-orb orb-1 absolute w-[500px] h-[500px] bg-gradient-to-r ${colors.gradient} rounded-full blur-[100px] opacity-30`} data-speed="0.05"></div>
    <div class={`parallax-orb orb-2 absolute w-[400px] h-[400px] bg-gradient-to-r ${colors.gradient} rounded-full blur-[80px] opacity-25`} data-speed="0.03"></div>
    <div class="parallax-orb orb-4 absolute w-[600px] h-[600px] bg-gradient-to-r from-slate-800 to-slate-900 rounded-full blur-[100px] opacity-60" data-speed="0.02"></div>

    <!-- Grid pattern -->
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-10"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-slate-950/50 to-slate-950"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 container-custom py-24 lg:py-20">
    <div class={`grid items-center gap-10 lg:gap-16 ${showPanel ? 'lg:grid-cols-[1.05fr_0.95fr]' : ''}`}>
      <!-- Left column: message + CTAs + logos -->
      <div class="max-w-2xl">
        {badge && (
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/10 mb-6 animate-fade-in-down">
            <span class={`w-2 h-2 rounded-full bg-gradient-to-r ${colors.gradient} animate-pulse`}></span>
            <span class="text-white/90 font-medium text-sm">{badge}</span>
          </div>
        )}

        <h1 class="font-display text-[2.25rem] sm:text-5xl lg:text-6xl font-bold text-white mb-5 leading-[1.08] break-words hyphens-auto" lang={lang}>
          {headline}
        </h1>

        {subheadline && (
          <p class={`text-lg sm:text-xl font-semibold ${colors.accent} mb-5 animate-fade-in animation-delay-300`}>
            {subheadline}
          </p>
        )}

        <p class="text-base sm:text-lg text-slate-400 mb-8 animate-fade-in animation-delay-500">
          {description}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap gap-4 animate-fade-in animation-delay-700">
          <a
            href={`/${lang}/contact`}
            class="group inline-flex items-center gap-3 px-7 py-4 rounded-xl bg-white text-slate-900 hover:bg-slate-100 font-semibold text-base shadow-xl hover:shadow-2xl hover:scale-[1.03] transition-all duration-300"
          >
            {t(lang, 'cta.startProject')}
            <Icon name="arrow-right" size={20} class="group-hover:translate-x-1 transition-transform" />
          </a>
          <a
            href={`/${lang}/calculator`}
            class="inline-flex items-center gap-3 px-7 py-4 rounded-xl bg-white/10 backdrop-blur-sm border border-white/20 text-white font-semibold text-base hover:bg-white/20 hover:scale-[1.03] transition-all duration-300"
          >
            <span>🧮</span>
            {t(lang, 'cta.calculateBudget')}
          </a>
        </div>

        <!-- Client logo strip -->
        <div class="mt-10 animate-fade-in animation-delay-700">
          <p class="text-xs uppercase tracking-wider text-slate-500 mb-3">{lbl.trusted}</p>
          <div class="flex flex-wrap items-center gap-2.5">
            {heroLogos.map((c) => (
              <div class="h-9 w-[88px] bg-white/90 rounded-lg flex items-center justify-center px-2.5 shadow-sm">
                <img src={c.logo} alt={c.name} class="max-h-5 max-w-full object-contain" loading="eager" width="80" height="20" />
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right column: proof panel -->
      {showPanel && (
        <div class={`relative rounded-2xl bg-white/[0.06] backdrop-blur-md border border-white/10 p-6 sm:p-7 shadow-2xl ring-1 ${colors.ring} animate-fade-in animation-delay-500`}>
          {metrics.length > 0 && (
            <>
              <div class="flex items-center gap-2 mb-5">
                <span class={`w-2 h-2 rounded-full bg-gradient-to-r ${colors.gradient}`}></span>
                <span class="text-xs uppercase tracking-wider text-slate-400 font-semibold">{lbl.results}</span>
              </div>
              <div class="grid grid-cols-2 gap-x-6 gap-y-5 mb-6">
                {metrics.slice(0, 4).map((m) => (
                  <div>
                    <div class={`text-3xl sm:text-4xl font-bold font-display ${colors.accent} leading-none`}>{m.value}</div>
                    <div class="text-xs text-slate-400 mt-1.5 leading-tight">{m.label}</div>
                  </div>
                ))}
              </div>
            </>
          )}

          {proofPoints.length > 0 && (
            <div class={metrics.length > 0 ? 'pt-5 border-t border-white/10' : ''}>
              <p class="text-xs uppercase tracking-wider text-slate-400 font-semibold mb-3">{lbl.whatYouGet}</p>
              <ul class="space-y-2.5">
                {proofPoints.slice(0, 4).map((p) => (
                  <li class="flex items-start gap-2.5 text-sm text-slate-200">
                    <span class={`mt-0.5 flex-shrink-0 w-4 h-4 rounded-full bg-gradient-to-r ${colors.gradient} flex items-center justify-center`}>
                      <svg class="w-2.5 h-2.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                    </span>
                    <span>{p}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {testimonial && (
            <figure class="mt-6 pt-5 border-t border-white/10">
              <blockquote class="text-sm text-slate-300 italic leading-relaxed">“{testimonial.quote}”</blockquote>
              <figcaption class="mt-2 text-xs text-slate-400">
                <span class="text-slate-200 font-medium not-italic">{testimonial.author}</span>{testimonial.role ? `, ${testimonial.role}` : ''}{testimonial.company ? ` — ${testimonial.company}` : ''}
              </figcaption>
            </figure>
          )}
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .orb-1 { top: 8%; left: -10%; }
  .orb-2 { bottom: 15%; right: -5%; }
  .orb-4 { top: 40%; left: 30%; }

  .animation-delay-300 { animation-delay: 300ms; }
  .animation-delay-500 { animation-delay: 500ms; }
  .animation-delay-700 { animation-delay: 700ms; }

  @keyframes fade-in { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes fade-in-down { from { opacity: 0; transform: translateY(-20px); } to { opacity: 1; transform: translateY(0); } }

  .animate-fade-in { animation: fade-in 0.7s ease forwards; opacity: 0; }
  .animate-fade-in-down { animation: fade-in-down 0.7s ease forwards; opacity: 0; }

  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in, .animate-fade-in-down { animation: none; opacity: 1; transform: none; }
    .parallax-orb { animation: none !important; }
  }
</style>

<script>
  // Mouse parallax for orbs (skipped under reduced motion)
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const heroSection = document.querySelector('.hero-section');
  const orbs = document.querySelectorAll('.parallax-orb');

  if (!prefersReduced && heroSection && orbs.length > 0) {
    let mouseX = 0, mouseY = 0, currentX = 0, currentY = 0;
    heroSection.addEventListener('mousemove', (e) => {
      const rect = heroSection.getBoundingClientRect();
      mouseX = ((e as MouseEvent).clientX - rect.left - rect.width / 2) / rect.width;
      mouseY = ((e as MouseEvent).clientY - rect.top - rect.height / 2) / rect.height;
    });
    function animate() {
      currentX += (mouseX - currentX) * 0.05;
      currentY += (mouseY - currentY) * 0.05;
      orbs.forEach((orb) => {
        const speed = parseFloat(orb.getAttribute('data-speed') || '0.05');
        (orb as HTMLElement).style.transform = `translate(${currentX * 100 * speed}px, ${currentY * 100 * speed}px)`;
      });
      requestAnimationFrame(animate);
    }
    animate();
  }
</script>
