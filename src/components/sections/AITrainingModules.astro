---
import { type Language } from '@/i18n/config';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const translations = {
  en: {
    badge: "Formats & pricing",
    headline: "Three formats. You set the intensity.",
    subtitle: "The price is per session and doesn't depend on how many people attend. The longer the session, the more your teams get hands-on with their own files.",
    priceLabelRemote: "Remote",
    priceLabelOnsite: "On-site",
    recommended: "Recommended",
    formats: [
      {
        name: "Discovery",
        duration: "1h",
        description: "A high-level panorama: what AI really changes at work, what it doesn't, where the tools stand. We present and answer questions. No exercises.",
        remote: "€700",
        onsite: "€950",
        highlighted: false
      },
      {
        name: "Awareness",
        duration: "2h",
        description: "The panorama plus the foundations: data security and the CRAFT prompting method, with a first hands-on exercise so everyone has touched it.",
        remote: "€1,200",
        onsite: "€1,500",
        highlighted: false
      },
      {
        name: "Hands-on workshop",
        duration: "3h30",
        description: "One topic in depth, lots of exercises: everyone works on their own files. The only format people leave actually knowing how to do it.",
        remote: "€1,700",
        onsite: "€2,100",
        highlighted: true
      }
    ],
    priceNote: "Excl. VAT, per session, regardless of headcount. A surcharge applies beyond 20 people in a plenary session (see below). On-site adds a travel & accommodation flat fee per day, mutualized if several sessions run the same day.",
    includedTitle: "What's included",
    included: [
      "Scoping calls with your teams",
      "A 100% custom program, built on your real cases",
      "Delivery by a hands-on practitioner, not a theorist",
      "Interactive training material handed to every participant",
      "Video recording and written transcript of the session",
      "Tool and best-practice recommendations for your context",
      "Per-session pricing, headcount-independent (except the plenary surcharge)",
      "The volume discount, from the second session"
    ],
    excludedTitle: "Not included",
    excluded: [
      "The on-site surcharge and the travel & accommodation flat fee (neither applies to remote formats)",
      "AI tool subscriptions (Claude Pro, ChatGPT Plus, ~€20/mo per user) — we advise on the best picks",
      "Room rental if your premises aren't suitable",
      "Development of agents or automations on your infrastructure (separate project, quoted separately)",
      "Operational management of your ad campaigns (separate offer)"
    ],
    scaleTitle: "The more sessions, the less each one costs",
    scaleSubtitle: "A large part of our work (understanding your organization, designing the program, preparing demos on your files) is done once and benefits every session that follows. We pass it back to you.",
    scale: [
      { count: "2 sessions", discount: "-5%" },
      { count: "3-4 sessions", discount: "-10%" },
      { count: "5-7 sessions", discount: "-15%" },
      { count: "8 sessions +", discount: "-20%" }
    ],
    scaleNote: "Applied across all sessions in the program, formats mixed. Sessions don't have to run in the same month — a program can spread over the semester.",
    groupTitle: "How many people per session?",
    groupSubtitle: "The price doesn't depend on headcount, so you can gather widely. But let's be transparent about one thing few providers will tell you: group size changes what we can do for you — not a matter of price, a matter of available attention.",
    groups: [
      { size: "Up to 12", label: "Maximum personalization", text: "The ideal format, and the cap we set for the hands-on workshop. We work on each person's files, every question gets answered, and we adapt the pace live." },
      { size: "13-20", label: "Good compromise", text: "Still very effective for discovery and awareness: small enough for questions to flow. Individual cases are followed less closely." },
      { size: "20+", label: "Plenary +15%", text: "We teach, demo and answer the group's questions, but we no longer coach anyone individually. A surcharge of +15% beyond 20, +30% beyond 50." }
    ],
    positioningTitle: "A complete training, at a fair price",
    positioningText: "On the market, a tailored AI training is commonly billed €450 to €750 per participant, and some ask €5,000+ for a few hours — often without deep customization or a recording. Our hands-on workshop at €1,700 for twelve works out to €142 per head, custom scoping, interactive material and replay included.",
    positioningStat: "€142",
    positioningStatLabel: "per head for a hands-on workshop of 12, vs €450-750 at market rate",
    cta: "Get your custom quote"
  },
  fr: {
    badge: "Formats & tarifs",
    headline: "Trois formats. Vous réglez l'intensité.",
    subtitle: "Le tarif est par session et ne dépend pas du nombre de participants. Plus la session est longue, plus vos équipes manipulent leurs propres fichiers.",
    priceLabelRemote: "À distance",
    priceLabelOnsite: "Sur site",
    recommended: "Recommandé",
    formats: [
      {
        name: "Découverte",
        duration: "1h",
        description: "Un panorama à haut niveau : ce que l'IA change concrètement au travail, ce qu'elle ne fait pas, où en sont les outils. Nous présentons et répondons aux questions. Pas d'exercice.",
        remote: "700 €",
        onsite: "950 €",
        highlighted: false
      },
      {
        name: "Sensibilisation",
        duration: "2h",
        description: "Le panorama, plus les fondations : sécurité des données et méthode de prompting CRAFT, avec un premier exercice pour que chacun ait touché du doigt.",
        remote: "1 200 €",
        onsite: "1 500 €",
        highlighted: false
      },
      {
        name: "Atelier pratique",
        duration: "3h30",
        description: "Un axe métier en profondeur, beaucoup d'exercices : chacun manipule ses propres fichiers. Le seul format dont les participants ressortent en sachant faire.",
        remote: "1 700 €",
        onsite: "2 100 €",
        highlighted: true
      }
    ],
    priceNote: "Hors TVA, par session, quel que soit le nombre de participants. Une majoration s'applique au-delà de 20 personnes en session plénière (voir plus bas). En présentiel s'ajoute un forfait transport et hébergement par journée, mutualisé si plusieurs sessions se tiennent le même jour.",
    includedTitle: "Ce qui est compris",
    included: [
      "Cadrage et échanges préalables avec vos équipes",
      "Un programme 100 % sur mesure, bâti sur vos cas réels",
      "Une animation par un praticien, pas par un théoricien",
      "Un support de formation interactif remis à chaque participant",
      "Enregistrement vidéo et transcription écrite de la session",
      "Recommandations d'outils et de bonnes pratiques adaptées à votre contexte",
      "Un tarif par session qui ne dépend pas de l'effectif (hors majoration plénière)",
      "La remise volume, dès la deuxième session"
    ],
    excludedTitle: "Non compris",
    excluded: [
      "Le supplément présentiel et le forfait transport et hébergement (aucun des deux sur les formats à distance)",
      "Les abonnements aux outils IA (Claude Pro, ChatGPT Plus, ~20 €/mois par utilisateur) — nous vous conseillons sur les choix",
      "La location d'une salle si vos locaux ne conviennent pas",
      "Le développement d'agents ou d'automatisations sur votre infrastructure (projet distinct, chiffré séparément)",
      "La gestion opérationnelle de vos campagnes publicitaires (offre distincte)"
    ],
    scaleTitle: "Plus vous prenez de sessions, moins chacune coûte",
    scaleSubtitle: "Une part importante de notre travail (comprendre votre organisation, concevoir le programme, préparer les démonstrations sur vos fichiers) se fait une seule fois et bénéficie à toutes les sessions suivantes. Nous vous la répercutons.",
    scale: [
      { count: "2 sessions", discount: "-5 %" },
      { count: "3-4 sessions", discount: "-10 %" },
      { count: "5-7 sessions", discount: "-15 %" },
      { count: "8 sessions +", discount: "-20 %" }
    ],
    scaleNote: "Remise appliquée sur l'ensemble des sessions du parcours, formats mélangés. Les sessions n'ont pas besoin de se tenir dans le même mois : un parcours peut s'étaler sur le semestre.",
    groupTitle: "Combien de personnes par session ?",
    groupSubtitle: "Le tarif ne dépend pas de l'effectif, vous pouvez donc réunir large. Mais soyons transparents sur un point que peu d'organismes disent : la taille du groupe change ce que nous sommes capables de faire — pas une question de prix, une question d'attention disponible.",
    groups: [
      { size: "Jusqu'à 12", label: "Personnalisation maximale", text: "Le format idéal, et la limite que nous fixons pour l'atelier pratique. Nous travaillons sur les fichiers de chacun, chaque question trouve sa réponse, et nous adaptons le rythme en direct." },
      { size: "13-20", label: "Bon compromis", text: "Toujours très efficace en découverte et sensibilisation : assez petit pour que les questions circulent. Les cas individuels sont suivis moins finement." },
      { size: "20+", label: "Plénière +15 %", text: "Nous transmettons, démontrons et répondons aux questions du groupe, mais nous n'accompagnons plus personne individuellement. Majoration de +15 % au-delà de 20, +30 % au-delà de 50." }
    ],
    positioningTitle: "Une formation complète, à un tarif juste",
    positioningText: "Sur le marché, une formation IA sur mesure se facture couramment 450 à 750 € par participant, et certains demandent 5 000 € et plus pour quelques heures, souvent sans conception personnalisée poussée ni restitution vidéo. Notre atelier pratique à 1 700 € pour douze revient à 142 € par tête, cadrage sur mesure, support interactif et replay compris.",
    positioningStat: "142 €",
    positioningStatLabel: "par tête pour un atelier pratique de 12, contre 450-750 € au prix du marché",
    cta: "Obtenir un devis sur mesure"
  }
};

const t = translations[lang] || translations.en;
---

<section class="py-24 bg-white overflow-hidden">
  <div class="container-custom">
    <!-- Header -->
    <div class="max-w-3xl mb-14 animate-on-scroll">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-cyan-100 text-cyan-700 font-medium mb-6">
        <Icon name="book-open" size={16} />
        <span>{t.badge}</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-4">
        {t.headline}
      </h2>
      <p class="text-lg text-slate-600 leading-relaxed">{t.subtitle}</p>
    </div>

    <!-- Formats grid -->
    <div class="grid md:grid-cols-3 gap-6 items-stretch">
      {t.formats.map((f, index) => (
        <div
          class={`
            fmt-card relative flex flex-col p-8 rounded-2xl border transition-all duration-300 animate-on-scroll
            ${f.highlighted
              ? 'bg-slate-950 text-white border-slate-800 shadow-2xl shadow-cyan-500/10'
              : 'bg-white border-slate-200 hover:border-cyan-200 hover:shadow-lg'}
          `}
          style={`animation-delay: ${index * 100}ms`}
        >
          {f.highlighted && (
            <div class="absolute -top-3 left-8">
              <span class="px-4 py-1 bg-gradient-to-r from-cyan-400 to-blue-500 text-white text-xs font-semibold uppercase tracking-wider rounded-full shadow-lg">
                {t.recommended}
              </span>
            </div>
          )}

          <div class="flex items-baseline justify-between mb-4">
            <h3 class={`text-xl font-bold ${f.highlighted ? 'text-white' : 'text-slate-900'}`}>{f.name}</h3>
            <span class={`text-sm font-semibold px-3 py-1 rounded-full ${f.highlighted ? 'bg-white/10 text-cyan-300' : 'bg-cyan-50 text-cyan-700'}`}>{f.duration}</span>
          </div>

          <p class={`text-sm leading-relaxed mb-6 flex-1 ${f.highlighted ? 'text-slate-300' : 'text-slate-600'}`}>{f.description}</p>

          <div class={`grid grid-cols-2 gap-3 pt-5 border-t ${f.highlighted ? 'border-white/10' : 'border-slate-100'}`}>
            <div>
              <div class={`text-[11px] uppercase tracking-wider mb-1 ${f.highlighted ? 'text-slate-400' : 'text-slate-400'}`}>{t.priceLabelRemote}</div>
              <div class={`text-2xl font-bold ${f.highlighted ? 'text-white' : 'text-slate-900'}`}>{f.remote}</div>
            </div>
            <div>
              <div class="text-[11px] uppercase tracking-wider mb-1 text-slate-400">{t.priceLabelOnsite}</div>
              <div class={`text-2xl font-bold ${f.highlighted ? 'bg-gradient-to-r from-cyan-300 to-blue-300 bg-clip-text text-transparent' : 'text-slate-500'}`}>{f.onsite}</div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <p class="text-xs text-slate-500 leading-relaxed mt-5 max-w-4xl">{t.priceNote}</p>

    <!-- Included / Not included -->
    <div class="grid lg:grid-cols-2 gap-6 mt-16">
      <div class="rounded-2xl bg-gradient-to-br from-cyan-50 to-white border border-cyan-100 p-8 animate-on-scroll">
        <h3 class="text-lg font-bold text-slate-900 mb-5 flex items-center gap-2">
          <span class="w-6 h-6 rounded-full bg-cyan-500 flex items-center justify-center flex-shrink-0">
            <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
          </span>
          {t.includedTitle}
        </h3>
        <ul class="space-y-3">
          {t.included.map(item => (
            <li class="flex items-start gap-2.5 text-sm text-slate-700">
              <svg class="w-4 h-4 text-cyan-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="rounded-2xl bg-slate-50 border border-slate-200 p-8 animate-on-scroll" style="animation-delay:100ms">
        <h3 class="text-lg font-bold text-slate-900 mb-5 flex items-center gap-2">
          <span class="w-6 h-6 rounded-full bg-slate-300 flex items-center justify-center flex-shrink-0">
            <svg class="w-3.5 h-3.5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
          </span>
          {t.excludedTitle}
        </h3>
        <ul class="space-y-3">
          {t.excluded.map(item => (
            <li class="flex items-start gap-2.5 text-sm text-slate-500">
              <svg class="w-4 h-4 text-slate-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Volume discounts -->
    <div class="mt-16 animate-on-scroll">
      <div class="max-w-3xl mb-8">
        <h3 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">{t.scaleTitle}</h3>
        <p class="text-slate-600 leading-relaxed">{t.scaleSubtitle}</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {t.scale.map((s, i) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-6 text-center hover:border-cyan-200 hover:shadow-md transition-all duration-300" style={`animation-delay:${i * 80}ms`}>
            <div class="text-3xl md:text-4xl font-bold bg-gradient-to-r from-cyan-500 to-blue-600 bg-clip-text text-transparent">{s.discount}</div>
            <div class="text-sm text-slate-500 mt-2">{s.count}</div>
          </div>
        ))}
      </div>
      <p class="text-xs text-slate-500 leading-relaxed mt-4 max-w-4xl">{t.scaleNote}</p>
    </div>

    <!-- Group size -->
    <div class="mt-16 animate-on-scroll">
      <div class="max-w-3xl mb-8">
        <h3 class="text-2xl md:text-3xl font-bold text-slate-900 mb-3">{t.groupTitle}</h3>
        <p class="text-slate-600 leading-relaxed">{t.groupSubtitle}</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {t.groups.map((g, i) => (
          <div class={`rounded-2xl border p-7 ${i === 0 ? 'border-cyan-200 bg-cyan-50/50' : 'border-slate-200 bg-white'}`}>
            <div class="text-2xl font-bold text-slate-900 mb-1">{g.size}</div>
            <div class={`text-sm font-semibold mb-3 ${i === 0 ? 'text-cyan-700' : 'text-slate-500'}`}>{g.label}</div>
            <p class="text-sm text-slate-600 leading-relaxed">{g.text}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Positioning -->
    <div class="mt-16 rounded-3xl bg-slate-950 text-white p-8 lg:p-12 relative overflow-hidden animate-on-scroll">
      <div class="absolute -top-20 -right-20 w-72 h-72 bg-cyan-500/20 rounded-full blur-[100px]"></div>
      <div class="relative z-10 grid lg:grid-cols-[1.4fr_1fr] gap-8 items-center">
        <div>
          <h3 class="text-2xl md:text-3xl font-bold mb-4">{t.positioningTitle}</h3>
          <p class="text-slate-300 leading-relaxed">{t.positioningText}</p>
        </div>
        <div class="text-center lg:text-left lg:border-l lg:border-white/10 lg:pl-8">
          <div class="text-5xl md:text-6xl font-bold bg-gradient-to-r from-cyan-300 to-blue-300 bg-clip-text text-transparent">{t.positioningStat}</div>
          <div class="text-sm text-slate-400 mt-3 leading-relaxed">{t.positioningStatLabel}</div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-14 animate-on-scroll">
      <a
        href={`/${lang}/contact`}
        class="inline-flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-cyan-500 to-blue-600 text-white font-semibold rounded-xl hover:shadow-xl hover:shadow-cyan-500/25 hover:scale-105 transition-all duration-300"
      >
        <span>{t.cta}</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .fmt-card {
    animation: fmt-fade-up 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    opacity: 0;
    transform: translateY(24px);
  }

  @keyframes fmt-fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .fmt-card { animation: none; opacity: 1; transform: none; }
  }
</style>
