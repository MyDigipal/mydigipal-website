---
import { type Language } from '@/i18n/config';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const translations = {
  en: {
    badge: "For your employees",
    headline: "What your teams walk away with",
    intro: "The training is built for the people who use it every day. Here is what changes for them, from the first hour to the advanced use cases.",
    benefits: [
      {
        icon: "cloud",
        step: "01",
        title: "Overcome the fear of AI",
        description: "Many employees feel intimidated by AI or see it as too \"technical\". We make it accessible and practical, showing step by step what's possible, and the feedback is always overwhelmingly positive."
      },
      {
        icon: "prompt",
        step: "02",
        title: "Master better prompting",
        description: "Most people think \"AI doesn't work\" simply because they don't know how to ask. We teach the prompting techniques that unlock accurate, high-quality, usable outputs."
      },
      {
        icon: "discover",
        step: "03",
        title: "Discover what AI can really do",
        description: "From summarizing complex documents to generating images, creating content or automating workflows, your teams explore the full potential and leave knowing exactly how to use it day to day."
      },
      {
        icon: "ambassador",
        step: "04",
        title: "Become an AI ambassador",
        description: "Once they master the tools and techniques, participants share what they've learned and help colleagues adopt AI, naturally spreading best practices across the team."
      },
      {
        icon: "advanced",
        step: "05",
        title: "Unlock advanced use cases",
        description: "The training doesn't stop at the basics. We help identify the complex opportunities where AI can automate critical processes and bring real innovation to your company."
      }
    ]
  },
  fr: {
    badge: "Pour vos employés",
    headline: "Ce que vos équipes en retirent",
    intro: "La formation est pensée pour celles et ceux qui l'utilisent au quotidien. Voici ce qui change pour eux, de la première heure jusqu'aux cas d'usage avancés.",
    benefits: [
      {
        icon: "cloud",
        step: "01",
        title: "Surmonter la peur de l'IA",
        description: "Beaucoup d'employés se sentent intimidés par l'IA ou la voient comme trop \"technique\". Nous la rendons accessible et concrète, en montrant pas à pas ce qui est possible, et les retours sont toujours extrêmement positifs."
      },
      {
        icon: "prompt",
        step: "02",
        title: "Maîtriser le prompting",
        description: "La plupart des gens pensent que \"l'IA ne fonctionne pas\" simplement parce qu'ils ne savent pas la solliciter. Nous enseignons les techniques qui débloquent des résultats précis, de qualité et exploitables."
      },
      {
        icon: "discover",
        step: "03",
        title: "Découvrir ce que l'IA peut vraiment faire",
        description: "De la synthèse de documents complexes à la génération d'images, la création de contenu ou l'automatisation de workflows, vos équipes explorent tout le potentiel et savent exactement comment l'utiliser au quotidien."
      },
      {
        icon: "ambassador",
        step: "04",
        title: "Devenir ambassadeur IA",
        description: "Une fois les outils et techniques maîtrisés, les participants partagent leurs apprentissages et aident leurs collègues à adopter l'IA, diffusant naturellement les bonnes pratiques dans l'équipe."
      },
      {
        icon: "advanced",
        step: "05",
        title: "Débloquer les cas d'usage avancés",
        description: "La formation ne s'arrête pas aux bases. Nous aidons à identifier les opportunités complexes où l'IA peut automatiser des processus critiques et apporter une vraie innovation à votre entreprise."
      }
    ]
  }
};

const t = translations[lang] || translations.en;

const icons: Record<string, string> = {
  cloud: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>`,
  prompt: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
  discover: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>`,
  ambassador: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>`,
  advanced: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`
};

const [feature, ...rest] = t.benefits;
---

<section class="py-24 bg-gradient-to-b from-white via-cyan-50/40 to-white overflow-hidden">
  <div class="container-custom">
    <!-- Header -->
    <div class="max-w-3xl mb-14 animate-on-scroll">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-cyan-100 text-cyan-700 font-medium mb-6">
        <span class="w-2 h-2 bg-cyan-500 rounded-full"></span>
        <span>{t.badge}</span>
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-slate-900 mb-5">
        {t.headline}
      </h2>
      <p class="text-lg text-slate-600 leading-relaxed">{t.intro}</p>
    </div>

    <div class="grid lg:grid-cols-3 gap-6">
      <!-- Featured (first benefit) -->
      <div class="emp-card lg:row-span-2 relative overflow-hidden rounded-3xl bg-gradient-to-br from-slate-900 via-slate-900 to-blue-950 text-white p-8 lg:p-10 shadow-xl animate-on-scroll">
        <div class="absolute -top-16 -right-16 w-56 h-56 bg-cyan-500/20 rounded-full blur-3xl"></div>
        <div class="relative z-10 flex flex-col h-full">
          <div class="flex items-center justify-between mb-8">
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-cyan-400 to-blue-500 flex items-center justify-center text-white shadow-lg shadow-cyan-500/30">
              <Fragment set:html={icons[feature.icon]} />
            </div>
            <span class="text-5xl font-bold text-white/10 font-display leading-none">{feature.step}</span>
          </div>
          <h3 class="text-2xl font-bold mb-4">{feature.title}</h3>
          <p class="text-slate-300 leading-relaxed text-[15px]">{feature.description}</p>
        </div>
      </div>

      <!-- Remaining benefits -->
      {rest.map((b, index) => (
        <div
          class="emp-card group relative rounded-2xl bg-white border border-slate-200 p-7 shadow-sm hover:shadow-xl hover:border-cyan-200 hover:-translate-y-1 transition-all duration-300 animate-on-scroll"
          style={`animation-delay: ${(index + 1) * 90}ms`}
        >
          <div class="absolute left-0 top-7 bottom-7 w-1 rounded-full bg-gradient-to-b from-cyan-400 to-blue-500 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="flex items-center gap-4 mb-4">
            <div class="w-11 h-11 rounded-xl bg-cyan-50 text-cyan-600 flex items-center justify-center group-hover:bg-gradient-to-br group-hover:from-cyan-400 group-hover:to-blue-500 group-hover:text-white transition-all duration-300">
              <Fragment set:html={icons[b.icon]} />
            </div>
            <span class="text-2xl font-bold text-slate-200 font-display leading-none">{b.step}</span>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">{b.title}</h3>
          <p class="text-slate-600 text-sm leading-relaxed">{b.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .emp-card {
    animation: emp-fade-up 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    opacity: 0;
    transform: translateY(24px);
  }

  @keyframes emp-fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .emp-card { animation: none; opacity: 1; transform: none; }
  }
</style>
