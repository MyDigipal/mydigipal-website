---
/**
 * DashboardShowcase - Interactive AppMyDigital dashboard preview
 * Framer-style: dark background, glassmorphism, animated metrics, tab switching
 * Used on the Tracking & Reporting service page
 */
import type { Language } from '@/i18n/config';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const content = {
  en: {
    badge: "AppMyDigital Platform",
    headline: "Your marketing data, unified",
    subtitle: "A centralized dashboard accessible 24/7 that consolidates all your marketing data in real time. No more spreadsheets, no more siloed tools.",
    tabs: ["Overview", "Google Ads", "Meta Ads", "Cross-Channel"],
    cta: "See it in action",
    ctaLink: "/contact",
    features: [
      "Real-time data sync",
      "Cross-channel attribution",
      "AI-powered insights",
      "Custom exports",
    ],
    also: "Also available on",
  },
  fr: {
    badge: "Plateforme AppMyDigital",
    headline: "Vos données marketing, unifiées",
    subtitle: "Un tableau de bord centralisé accessible 24/7 qui consolide toutes vos données marketing en temps réel. Fini les tableurs, fini les outils cloisonnés.",
    tabs: ["Vue d'ensemble", "Google Ads", "Meta Ads", "Cross-Canal"],
    cta: "Voir en action",
    ctaLink: "/contact",
    features: [
      "Synchronisation temps réel",
      "Attribution cross-canal",
      "Insights propulsés par l'IA",
      "Exports personnalisés",
    ],
    also: "Également disponible sur",
  },
};

const c = content[lang] || content.en;
---

<section class="dashboard-showcase relative py-24 lg:py-32 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-[#0a0d1a]"></div>
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, rgb(148 163 184) 1px, transparent 1px); background-size: 28px 28px;"></div>
  <div class="absolute top-0 left-1/3 w-[500px] h-[400px] rounded-full bg-teal-900/20 blur-[120px]"></div>
  <div class="absolute bottom-0 right-1/4 w-[400px] h-[300px] rounded-full bg-indigo-900/20 blur-[100px]"></div>

  <div class="relative z-10 container-custom">
    <!-- Header -->
    <div class="text-center mb-14 animate-on-scroll">
      <span class="inline-block px-4 py-1.5 text-sm font-medium tracking-wide uppercase text-teal-400 border border-teal-500/30 rounded-full mb-6">
        {c.badge}
      </span>
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-white tracking-tight mb-4">
        {c.headline}
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed">
        {c.subtitle}
      </p>
    </div>

    <!-- Dashboard mockup container -->
    <div class="max-w-5xl mx-auto animate-on-scroll">
      <!-- Tab navigation -->
      <div class="flex gap-1 mb-6 bg-white/5 backdrop-blur-sm rounded-xl p-1.5 max-w-fit mx-auto border border-white/10">
        {c.tabs.map((tab, i) => (
          <button
            class={`dash-tab px-5 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 ${i === 0 ? 'bg-white/10 text-white' : 'text-slate-400 hover:text-white hover:bg-white/5'}`}
            data-tab={i}
          >
            {tab}
          </button>
        ))}
      </div>

      <!-- Browser frame -->
      <div class="dash-browser rounded-2xl overflow-hidden border border-white/10 bg-[#111427] shadow-2xl shadow-black/40">
        <!-- Browser chrome -->
        <div class="flex items-center gap-3 px-5 py-3.5 bg-[#0d1020] border-b border-white/5">
          <div class="flex gap-2">
            <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
            <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
            <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
          </div>
          <div class="flex-1 flex justify-center">
            <div class="px-4 py-1 rounded-md bg-white/5 text-xs text-slate-500 font-mono">
              app.mydigipal.com/dashboard/overview
            </div>
          </div>
        </div>

        <!-- Dashboard content -->
        <div class="p-6 md:p-8">
          <!-- Panel 0: Overview (default visible) -->
          <div class="dash-panel active" data-panel="0">
            <!-- Dashboard header -->
            <div class="flex items-center justify-between mb-6">
              <div>
                <h3 class="text-lg font-bold text-white">{lang === 'fr' ? 'Vue d\'ensemble' : 'Performance Overview'}</h3>
                <p class="text-sm text-slate-500">{lang === 'fr' ? 'Performance multicanal en temps réel' : 'Real-time multi-channel performance'}</p>
              </div>
              <div class="px-3 py-1.5 rounded-md bg-white/5 border border-white/10 text-xs text-slate-400">
                {lang === 'fr' ? 'Mars 2026' : 'March 2026'}
              </div>
            </div>

            <!-- KPI row -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
              <div class="kpi-card p-4 rounded-xl bg-white/[0.03] border border-white/5">
                <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">{lang === 'fr' ? 'Leads totaux' : 'Total Leads'}</div>
                <div class="text-2xl font-bold text-white kpi-number" data-target="1247">0</div>
                <div class="text-xs text-emerald-400 mt-1">+18% vs prev.</div>
              </div>
              <div class="kpi-card p-4 rounded-xl bg-white/[0.03] border border-white/5">
                <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">{lang === 'fr' ? 'Coût par lead' : 'Cost per Lead'}</div>
                <div class="text-2xl font-bold text-white">
                  <span class="kpi-number" data-target="54">0</span> <span class="text-sm text-slate-500">EUR</span>
                </div>
                <div class="text-xs text-emerald-400 mt-1">-12% vs prev.</div>
              </div>
              <div class="kpi-card p-4 rounded-xl bg-white/[0.03] border border-white/5">
                <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">{lang === 'fr' ? 'Dépense totale' : 'Total Spend'}</div>
                <div class="text-2xl font-bold text-white">
                  <span class="kpi-number" data-target="24580">0</span> <span class="text-sm text-slate-500">EUR</span>
                </div>
                <div class="text-xs text-slate-400 mt-1">{lang === 'fr' ? 'Budget consommé : 94%' : 'Budget consumed: 94%'}</div>
              </div>
              <div class="kpi-card p-4 rounded-xl bg-white/[0.03] border border-white/5">
                <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">ROAS</div>
                <div class="text-2xl font-bold text-white">
                  <span class="kpi-number" data-target="4.2" data-decimals="1">0</span><span class="text-sm text-slate-500">x</span>
                </div>
                <div class="text-xs text-emerald-400 mt-1">+0.6 vs prev.</div>
              </div>
            </div>

            <!-- Channel breakdown -->
            <div class="grid md:grid-cols-3 gap-3">
              <div class="channel-card p-4 rounded-xl bg-white/[0.03] border border-white/5 border-l-2 border-l-blue-500">
                <div class="text-xs text-slate-500 uppercase tracking-wider mb-2">Google Ads</div>
                <div class="text-xl font-bold text-white mb-1">526 <span class="text-sm font-normal text-slate-500">leads</span></div>
                <div class="text-xs text-slate-400">CPL 68 EUR - Conv. 5.8%</div>
                <div class="mt-3 h-1.5 bg-white/5 rounded-full overflow-hidden">
                  <div class="h-full bg-blue-500 rounded-full" style="width: 42%"></div>
                </div>
              </div>
              <div class="channel-card p-4 rounded-xl bg-white/[0.03] border border-white/5 border-l-2 border-l-indigo-500">
                <div class="text-xs text-slate-500 uppercase tracking-wider mb-2">Meta Ads</div>
                <div class="text-xl font-bold text-white mb-1">612 <span class="text-sm font-normal text-slate-500">leads</span></div>
                <div class="text-xs text-slate-400">CPL 42 EUR - Conv. 4.2%</div>
                <div class="mt-3 h-1.5 bg-white/5 rounded-full overflow-hidden">
                  <div class="h-full bg-indigo-500 rounded-full" style="width: 49%"></div>
                </div>
              </div>
              <div class="channel-card p-4 rounded-xl bg-white/[0.03] border border-white/5 border-l-2 border-l-emerald-500">
                <div class="text-xs text-slate-500 uppercase tracking-wider mb-2">{lang === 'fr' ? 'Trafic Organique' : 'Organic Traffic'}</div>
                <div class="text-xl font-bold text-white mb-1">4,830 <span class="text-sm font-normal text-slate-500">sessions</span></div>
                <div class="text-xs text-slate-400">+22% vs prev.</div>
                <div class="mt-3 h-1.5 bg-white/5 rounded-full overflow-hidden">
                  <div class="h-full bg-emerald-500 rounded-full" style="width: 65%"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Panel 1: Google Ads -->
          <div class="dash-panel hidden" data-panel="1">
            <div class="flex items-center justify-between mb-6">
              <div>
                <h3 class="text-lg font-bold text-white">Google Ads Performance</h3>
                <p class="text-sm text-slate-500">Search, Display, YouTube & Performance Max</p>
              </div>
              <div class="px-3 py-1.5 rounded-md bg-blue-500/10 border border-blue-500/20 text-xs text-blue-400">Live</div>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
              <div class="p-4 rounded-xl bg-white/[0.03] border border-white/5">
                <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">Impressions</div>
                <div class="text-2xl font-bold text-white">184K</div>
              </div>
              <div class="p-4 rounded-xl bg-white/[0.03] border border-white/5">
                <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">Clicks</div>
                <div class="text-2xl font-bold text-white">9,124</div>
              </div>
              <div class="p-4 rounded-xl bg-white/[0.03] border border-white/5">
                <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">CTR</div>
                <div class="text-2xl font-bold text-white">4.96%</div>
              </div>
              <div class="p-4 rounded-xl bg-white/[0.03] border border-white/5">
                <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">Conversions</div>
                <div class="text-2xl font-bold text-white">526</div>
                <div class="text-xs text-emerald-400 mt-1">+15%</div>
              </div>
            </div>

            <!-- Campaign table -->
            <div class="rounded-xl bg-white/[0.02] border border-white/5 overflow-hidden">
              <div class="grid grid-cols-5 gap-4 px-4 py-3 text-xs text-slate-500 uppercase tracking-wider border-b border-white/5">
                <div>Campaign</div><div>Spend</div><div>Leads</div><div>CPL</div><div>ROAS</div>
              </div>
              {[
                ['Search - Brand', '3,200', '142', '22 EUR', '8.2x'],
                ['Search - Generic', '5,840', '186', '31 EUR', '4.1x'],
                ['Performance Max', '4,120', '124', '33 EUR', '3.8x'],
                ['YouTube - Awareness', '1,890', '74', '26 EUR', '2.9x'],
              ].map(row => (
                <div class="grid grid-cols-5 gap-4 px-4 py-3 text-sm border-b border-white/[0.03] last:border-0">
                  <div class="text-white font-medium">{row[0]}</div>
                  <div class="text-slate-400">{row[1]}</div>
                  <div class="text-white">{row[2]}</div>
                  <div class="text-slate-400">{row[3]}</div>
                  <div class="text-emerald-400">{row[4]}</div>
                </div>
              ))}
            </div>
          </div>

          <!-- Panel 2: Meta Ads -->
          <div class="dash-panel hidden" data-panel="2">
            <div class="flex items-center justify-between mb-6">
              <div>
                <h3 class="text-lg font-bold text-white">Meta Ads Performance</h3>
                <p class="text-sm text-slate-500">Facebook, Instagram & Audience Network</p>
              </div>
              <div class="px-3 py-1.5 rounded-md bg-indigo-500/10 border border-indigo-500/20 text-xs text-indigo-400">Live</div>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
              <div class="p-4 rounded-xl bg-white/[0.03] border border-white/5">
                <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">Reach</div>
                <div class="text-2xl font-bold text-white">312K</div>
              </div>
              <div class="p-4 rounded-xl bg-white/[0.03] border border-white/5">
                <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">{lang === 'fr' ? 'Clics lien' : 'Link Clicks'}</div>
                <div class="text-2xl font-bold text-white">14,580</div>
              </div>
              <div class="p-4 rounded-xl bg-white/[0.03] border border-white/5">
                <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">CPM</div>
                <div class="text-2xl font-bold text-white">8.40 EUR</div>
              </div>
              <div class="p-4 rounded-xl bg-white/[0.03] border border-white/5">
                <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">Leads</div>
                <div class="text-2xl font-bold text-white">612</div>
                <div class="text-xs text-emerald-400 mt-1">+24%</div>
              </div>
            </div>

            <!-- Ad sets -->
            <div class="grid md:grid-cols-2 gap-3">
              {[
                { name: 'Retargeting - Website Visitors', leads: '284', cpl: '35 EUR', status: 'Active' },
                { name: 'Lookalike - Top Customers', leads: '198', cpl: '48 EUR', status: 'Active' },
                { name: 'Interest - Industry Keywords', leads: '86', cpl: '52 EUR', status: 'Active' },
                { name: 'Dynamic Creative - Catalog', leads: '44', cpl: '38 EUR', status: 'Learning' },
              ].map(ad => (
                <div class="p-4 rounded-xl bg-white/[0.03] border border-white/5">
                  <div class="flex items-center justify-between mb-2">
                    <div class="text-sm font-medium text-white">{ad.name}</div>
                    <span class={`text-xs px-2 py-0.5 rounded-full ${ad.status === 'Active' ? 'bg-emerald-500/10 text-emerald-400' : 'bg-amber-500/10 text-amber-400'}`}>{ad.status}</span>
                  </div>
                  <div class="flex gap-4 text-xs text-slate-400">
                    <span>{ad.leads} leads</span>
                    <span>CPL {ad.cpl}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Panel 3: Cross-Channel -->
          <div class="dash-panel hidden" data-panel="3">
            <div class="flex items-center justify-between mb-6">
              <div>
                <h3 class="text-lg font-bold text-white">{lang === 'fr' ? 'Attribution Cross-Canal' : 'Cross-Channel Attribution'}</h3>
                <p class="text-sm text-slate-500">{lang === 'fr' ? 'Parcours de conversion consolidé' : 'Consolidated conversion paths'}</p>
              </div>
              <div class="px-3 py-1.5 rounded-md bg-teal-500/10 border border-teal-500/20 text-xs text-teal-400">AI-Powered</div>
            </div>

            <!-- Conversion funnel -->
            <div class="grid md:grid-cols-4 gap-3 mb-6">
              {[
                { stage: lang === 'fr' ? 'Impressions' : 'Impressions', value: '496K', change: '' },
                { stage: lang === 'fr' ? 'Visites' : 'Visits', value: '23,710', change: '4.8% CTR' },
                { stage: 'Leads', value: '1,247', change: '5.3% Conv.' },
                { stage: lang === 'fr' ? 'Ventes' : 'Sales', value: '89', change: '7.1% Close' },
              ].map((step, i) => (
                <div class="relative p-4 rounded-xl bg-white/[0.03] border border-white/5 text-center">
                  <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">{step.stage}</div>
                  <div class="text-2xl font-bold text-white">{step.value}</div>
                  {step.change && <div class="text-xs text-teal-400 mt-1">{step.change}</div>}
                  {i < 3 && (
                    <div class="hidden md:block absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/2 z-10">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgb(94 234 212 / 0.4)" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </div>
                  )}
                </div>
              ))}
            </div>

            <!-- Channel contribution bars -->
            <div class="p-5 rounded-xl bg-white/[0.03] border border-white/5">
              <div class="text-sm font-medium text-white mb-4">{lang === 'fr' ? 'Contribution par canal' : 'Channel Contribution'}</div>
              {[
                { name: 'Google Ads', pct: 42, color: 'bg-blue-500', value: '526 leads' },
                { name: 'Meta Ads', pct: 49, color: 'bg-indigo-500', value: '612 leads' },
                { name: lang === 'fr' ? 'Organique' : 'Organic', pct: 7, color: 'bg-emerald-500', value: '89 leads' },
                { name: 'Email', pct: 2, color: 'bg-amber-500', value: '20 leads' },
              ].map(ch => (
                <div class="flex items-center gap-3 mb-3 last:mb-0">
                  <div class="w-24 text-xs text-slate-400 shrink-0">{ch.name}</div>
                  <div class="flex-1 h-2.5 bg-white/5 rounded-full overflow-hidden">
                    <div class={`h-full ${ch.color} rounded-full transition-all duration-1000`} style={`width: ${ch.pct}%`}></div>
                  </div>
                  <div class="w-20 text-xs text-slate-400 text-right shrink-0">{ch.value}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Features + CTA below dashboard -->
    <div class="max-w-5xl mx-auto mt-12 flex flex-col md:flex-row items-center justify-between gap-8 animate-on-scroll">
      <div class="flex flex-wrap gap-x-6 gap-y-3">
        {c.features.map(feature => (
          <div class="flex items-center gap-2 text-sm text-slate-400">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgb(45 212 191)" stroke-width="2" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>{feature}</span>
          </div>
        ))}
      </div>

      <div class="flex items-center gap-6 shrink-0">
        <div class="text-xs text-slate-500">{c.also} Looker Studio & Power BI</div>
        <a
          href={`/${lang}${c.ctaLink}`}
          class="group inline-flex items-center gap-2 px-6 py-3 bg-white text-slate-900 font-semibold rounded-xl hover:bg-slate-100 active:scale-[0.98] transition-all duration-200"
        >
          <span>{c.cta}</span>
          <Icon name="arrow-right" size={16} class="group-hover:translate-x-0.5 transition-transform" />
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .kpi-card, .channel-card {
    transition: border-color 0.3s, background-color 0.3s;
  }

  .kpi-card:hover, .channel-card:hover {
    border-color: rgb(255 255 255 / 0.1);
    background-color: rgb(255 255 255 / 0.05);
  }

  .dash-panel {
    animation: panel-in 0.4s ease-out;
  }

  .dash-panel.hidden {
    display: none;
  }

  @keyframes panel-in {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Tab switching
    const tabs = document.querySelectorAll('.dash-tab');
    const panels = document.querySelectorAll('.dash-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const idx = tab.getAttribute('data-tab');

        tabs.forEach(t => {
          t.classList.remove('bg-white/10', 'text-white');
          t.classList.add('text-slate-400');
        });
        tab.classList.add('bg-white/10', 'text-white');
        tab.classList.remove('text-slate-400');

        panels.forEach(p => p.classList.add('hidden'));
        const target = document.querySelector(`.dash-panel[data-panel="${idx}"]`);
        if (target) {
          target.classList.remove('hidden');
          target.style.animation = 'none';
          target.offsetHeight;
          target.style.animation = '';
        }
      });
    });

    // KPI counter animation
    const animateCounters = () => {
      document.querySelectorAll('.kpi-number').forEach(el => {
        const target = parseFloat(el.getAttribute('data-target') || '0');
        const decimals = parseInt(el.getAttribute('data-decimals') || '0');
        const duration = 1200;
        const start = performance.now();

        const tick = (now: number) => {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = target * eased;

          if (decimals > 0) {
            el.textContent = current.toFixed(decimals);
          } else if (target >= 1000) {
            el.textContent = Math.round(current).toLocaleString('en-US');
          } else {
            el.textContent = Math.round(current).toString();
          }

          if (progress < 1) requestAnimationFrame(tick);
        };

        requestAnimationFrame(tick);
      });
    };

    // Trigger counter animation when visible
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateCounters();
          obs.disconnect();
        }
      });
    }, { threshold: 0.3 });

    const showcase = document.querySelector('.dashboard-showcase');
    if (showcase) obs.observe(showcase);
  });
</script>
