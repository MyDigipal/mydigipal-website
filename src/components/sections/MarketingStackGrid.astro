---
import { type Language } from '@/i18n/config';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const translations = {
  en: {
    badge: "Connected stack",
    headline: "20+ platforms. One interface.",
    subtitle:
      "From Google Ads to Lemlist through BigQuery : we connect everything your team already uses. Here's what we orchestrate in production for our clients.",
    proofTitle: "MCP Gateway in production",
    proofs: [
      { value: "244", label: "tools exposed" },
      { value: "21", label: "platforms connected" },
      { value: "18+", label: "active clients" },
    ],
  },
  fr: {
    badge: "Stack connectée",
    headline: "20+ plateformes. Une seule interface.",
    subtitle:
      "De Google Ads à Lemlist en passant par BigQuery : on connecte tout ce que votre équipe utilise déjà. Voici ce qu'on orchestre en production pour nos clients.",
    proofTitle: "MCP Gateway en production",
    proofs: [
      { value: "244", label: "outils exposés" },
      { value: "21", label: "plateformes connectées" },
      { value: "18+", label: "clients actifs" },
    ],
  },
};

const t = translations[lang] || translations.en;

type Category = "ppc" | "data" | "seo" | "sales" | "content" | "ops";

interface Platform {
  name: string;
  initials: string;
  color: string;
  category: Category;
  useCase: { en: string; fr: string };
}

const platforms: Platform[] = [
  { name: "Google Ads", initials: "GA", color: "#fbbc05", category: "ppc",
    useCase: { en: "Adjust budgets, create ad groups, export search terms", fr: "Ajuster budgets, créer ad groups, exporter search terms" } },
  { name: "Meta Ads", initials: "MA", color: "#0866ff", category: "ppc",
    useCase: { en: "Audiences, creatives, conversions, budget pacing", fr: "Audiences, créatifs, conversions, pacing de budget" } },
  { name: "LinkedIn Ads", initials: "Li", color: "#0a66c2", category: "ppc",
    useCase: { en: "B2B campaigns, sponsorships, performance metrics", fr: "Campagnes B2B, sponsorisés, métriques de performance" } },
  { name: "Google Analytics 4", initials: "G4", color: "#f9ab00", category: "data",
    useCase: { en: "Traffic, events and conversions by source", fr: "Trafic, événements et conversions par source" } },
  { name: "Search Console", initials: "SC", color: "#458cf5", category: "seo",
    useCase: { en: "Clicks, impressions, CTR by country and device", fr: "Clics, impressions, CTR par pays et device" } },
  { name: "BigQuery", initials: "BQ", color: "#669df6", category: "data",
    useCase: { en: "Query multi-account, detect anomalies, automate reports", fr: "Requêter multi-compte, détecter anomalies, automatiser rapports" } },
  { name: "Tag Manager", initials: "GT", color: "#246fdb", category: "data",
    useCase: { en: "Create tags, triggers, variables across accounts", fr: "Créer tags, déclencheurs, variables multi-comptes" } },
  { name: "Ahrefs", initials: "Ah", color: "#ff6a00", category: "seo",
    useCase: { en: "Backlinks, domain rating, keyword explorer, audit", fr: "Backlinks, domain rating, keyword explorer, audit" } },
  { name: "Lemlist", initials: "Le", color: "#8067e3", category: "sales",
    useCase: { en: "Launch campaigns, enrich leads, CRM webhooks", fr: "Lancer campagnes, enrichir leads, webhooks CRM" } },
  { name: "Airscale", initials: "As", color: "#10b981", category: "sales",
    useCase: { en: "Find emails, phones, LinkedIn profiles at scale", fr: "Trouver emails, téléphones, profils LinkedIn à grande échelle" } },
  { name: "ClickUp", initials: "Cu", color: "#7b68ee", category: "ops",
    useCase: { en: "Tasks, time tracking, docs, sprints, custom fields", fr: "Tâches, time tracking, docs, sprints, champs custom" } },
  { name: "Notion", initials: "No", color: "#0f0f0f", category: "content",
    useCase: { en: "Databases, relations, wikis, client knowledge bases", fr: "Bases de données, relations, wikis, bases de connaissances" } },
  { name: "Gmail", initials: "Gm", color: "#ea4335", category: "content",
    useCase: { en: "Search, drafts, reply with thread context", fr: "Recherche, brouillons, réponses en contexte de thread" } },
  { name: "Google Drive", initials: "Dr", color: "#1fa463", category: "content",
    useCase: { en: "Files, folders, sharing, uploads, shared drives", fr: "Fichiers, dossiers, partage, uploads, drives partagés" } },
  { name: "Sheets", initials: "Sh", color: "#0f9d58", category: "content",
    useCase: { en: "Read and write configs, briefs and reporting dashboards", fr: "Lire/écrire configs, briefs et dashboards de reporting" } },
  { name: "Docs", initials: "Do", color: "#4285f4", category: "content",
    useCase: { en: "Generate reports, update content, template exports", fr: "Générer rapports, mettre à jour contenu, exports templates" } },
  { name: "Slides", initials: "Sl", color: "#f4b400", category: "content",
    useCase: { en: "Replace text, export slide decks from data", fr: "Remplacer textes, exporter decks à partir de données" } },
  { name: "Calendar", initials: "Ca", color: "#4285f4", category: "ops",
    useCase: { en: "Create events, freebusy, multi-calendar scheduling", fr: "Créer événements, freebusy, planification multi-calendrier" } },
  { name: "n8n", initials: "n8", color: "#ea4b71", category: "ops",
    useCase: { en: "Build, version and run workflows from Claude", fr: "Construire, versionner et exécuter des workflows depuis Claude" } },
  { name: "Render", initials: "Re", color: "#46e3b7", category: "ops",
    useCase: { en: "Deploy services, env vars, logs, suspend & resume", fr: "Déployer services, env vars, logs, suspendre & reprendre" } },
];

const categoryColors: Record<Category, string> = {
  ppc: "bg-amber-100 text-amber-700 ring-amber-200",
  data: "bg-cyan-100 text-cyan-700 ring-cyan-200",
  seo: "bg-emerald-100 text-emerald-700 ring-emerald-200",
  sales: "bg-violet-100 text-violet-700 ring-violet-200",
  content: "bg-rose-100 text-rose-700 ring-rose-200",
  ops: "bg-slate-100 text-slate-700 ring-slate-200",
};

const categoryLabels: Record<Category, { en: string; fr: string }> = {
  ppc: { en: "Paid Media", fr: "Paid Media" },
  data: { en: "Data", fr: "Data" },
  seo: { en: "SEO", fr: "SEO" },
  sales: { en: "Sales", fr: "Sales" },
  content: { en: "Content", fr: "Contenu" },
  ops: { en: "Ops", fr: "Ops" },
};
---

<section class="relative overflow-hidden py-24 md:py-32 bg-[#f8f9fc]">
  <div class="absolute inset-0 pointer-events-none">
    <div
      class="absolute inset-0 opacity-[0.04]"
      style="background-image: radial-gradient(circle, #64748b 1px, transparent 1px); background-size: 28px 28px;"
    ></div>
  </div>

  <div class="container-custom relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-16 animate-on-scroll">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-cyan-100 text-cyan-700 text-sm font-medium mb-6">
        <span>{t.badge}</span>
      </div>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-slate-900 leading-tight mb-6">
        {t.headline}
      </h2>
      <p class="text-lg text-slate-500 leading-relaxed">{t.subtitle}</p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4 md:gap-5 mb-20">
      {
        platforms.map((p, i) => (
          <div
            class="stack-tile group relative animate-on-scroll"
            style={`animation-delay: ${Math.min(i * 40, 600)}ms`}
          >
            <div class="stack-card">
              <!-- Face -->
              <div class="stack-face">
                <div
                  class="w-12 h-12 rounded-xl flex items-center justify-center font-bold text-white text-sm shadow-md mb-3"
                  style={`background: linear-gradient(135deg, ${p.color}, ${p.color}cc)`}
                >
                  {p.initials}
                </div>
                <h3 class="font-semibold text-slate-900 text-sm leading-tight mb-1">
                  {p.name}
                </h3>
                <span
                  class={`inline-block text-[10px] font-medium uppercase tracking-wider px-2 py-0.5 rounded-full ring-1 ${categoryColors[p.category]}`}
                >
                  {categoryLabels[p.category][lang] || categoryLabels[p.category].en}
                </span>
              </div>

              <!-- Hover overlay -->
              <div class="stack-hover">
                <h3 class="font-semibold text-white text-sm mb-2">{p.name}</h3>
                <p class="text-xs text-slate-200 leading-relaxed">
                  {p.useCase[lang] || p.useCase.en}
                </p>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Proof badges -->
    <div class="relative">
      <div class="absolute inset-0 bg-gradient-to-r from-cyan-500/10 via-violet-500/10 to-emerald-500/10 rounded-3xl blur-2xl"></div>
      <div class="relative bg-white/80 backdrop-blur-xl border border-white/60 rounded-3xl p-8 md:p-12 shadow-xl">
        <div class="text-center mb-8">
          <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
            <span class="inline-block w-8 h-px bg-slate-300"></span>
            {t.proofTitle}
            <span class="inline-block w-8 h-px bg-slate-300"></span>
          </span>
        </div>
        <div class="grid grid-cols-3 gap-4 md:gap-8">
          {
            t.proofs.map((proof) => (
              <div class="text-center">
                <div class="font-display text-4xl md:text-6xl font-bold bg-gradient-to-br from-cyan-500 via-violet-500 to-emerald-500 bg-clip-text text-transparent mb-2">
                  {proof.value}
                </div>
                <div class="text-sm md:text-base text-slate-600 font-medium">
                  {proof.label}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .stack-tile {
    perspective: 800px;
  }

  .stack-card {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 1rem;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
  }

  .stack-tile:hover .stack-card {
    transform: rotateY(180deg);
  }

  .stack-face,
  .stack-hover {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 1rem;
    border-radius: 1rem;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .stack-face {
    background: #ffffff;
    border: 1px solid rgb(226 232 240);
    box-shadow: 0 2px 8px -2px rgba(15, 23, 42, 0.05);
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .stack-tile:hover .stack-face {
    border-color: rgb(103 232 249);
    box-shadow: 0 10px 30px -10px rgba(6, 182, 212, 0.3);
  }

  .stack-hover {
    background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%);
    transform: rotateY(180deg);
    justify-content: center;
    border: 1px solid rgba(139, 92, 246, 0.3);
  }

  @media (prefers-reduced-motion: reduce) {
    .stack-card {
      transition: none;
    }
    .stack-tile:hover .stack-card {
      transform: none;
    }
    .stack-hover {
      display: none;
    }
  }
</style>
