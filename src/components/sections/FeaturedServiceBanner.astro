---
/**
 * FeaturedServiceBanner - Premium section highlighting AI Content Creation
 * Design: Dark section with subtle warmth, Linear/Stripe inspired
 * Anti-patterns avoided: no purple-blue gradient CTA, no neon glow, no gradient text
 */
import type { Language } from '@/i18n/config';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const content = {
  en: {
    badge: "Featured Service",
    headline: "AI-Powered Content Creation",
    subtitle: "From strategy to publication, at scale. Human expertise meets AI efficiency to produce content that ranks and converts.",
    steps: [
      { icon: "mic", title: "Voice Study", description: "We analyze your brand's unique tone, audience, and positioning to build an AI writing profile" },
      { icon: "search", title: "SEO Research", description: "Data-driven topic selection based on search demand, competition gaps, and intent mapping" },
      { icon: "cpu", title: "AI Writing", description: "Human-supervised AI produces expert-level content - reviewed, edited, and fact-checked" },
      { icon: "share-2", title: "Publish", description: "Automated distribution across blog, social channels, email newsletters and more" },
    ],
    stats: [
      { value: "+300%", label: "organic traffic" },
      { value: "10x", label: "faster production" },
      { value: "60%", label: "cost reduction" },
    ],
    cta: "Discover AI Content",
    ctaLink: "/services/ai-content",
  },
  fr: {
    badge: "Service phare",
    headline: "Création de contenu par l'IA",
    subtitle: "De la stratégie à la publication, à grande échelle. L'expertise humaine rencontre l'efficacité de l'IA pour produire du contenu qui se positionne et convertit.",
    steps: [
      { icon: "mic", title: "Étude de voix", description: "Nous analysons le ton unique de votre marque, votre audience et votre positionnement" },
      { icon: "search", title: "Recherche SEO", description: "Sélection de sujets basée sur la demande, les opportunités et l'intention de recherche" },
      { icon: "cpu", title: "Rédaction IA", description: "L'IA supervisée produit du contenu expert - relu, édité et vérifié par nos équipes" },
      { icon: "share-2", title: "Publication", description: "Distribution automatisée sur blog, réseaux sociaux, newsletters et plus encore" },
    ],
    stats: [
      { value: "+300%", label: "trafic organique" },
      { value: "10x", label: "plus rapide" },
      { value: "60%", label: "réduction des coûts" },
    ],
    cta: "Découvrir AI Content",
    ctaLink: "/services/ai-content",
  },
};

const c = content[lang] || content.en;
---

<section class="featured-banner relative py-24 lg:py-32 overflow-hidden">
  <!-- Background: warm dark, not pure black -->
  <div class="absolute inset-0 bg-[#0c0f1a]"></div>

  <!-- Subtle dot grid pattern -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle, rgb(148 163 184) 1px, transparent 1px); background-size: 32px 32px;"></div>

  <!-- Ambient light - warm tones, no neon -->
  <div class="absolute top-0 left-1/3 w-[600px] h-[400px] rounded-full bg-indigo-900/30 blur-[150px] animate-drift"></div>
  <div class="absolute bottom-0 right-1/4 w-[500px] h-[350px] rounded-full bg-slate-800/40 blur-[120px] animate-drift" style="animation-delay: -8s;"></div>

  <div class="relative z-10 container-custom">
    <!-- Header -->
    <div class="text-center mb-16 animate-on-scroll">
      <span class="inline-block px-4 py-1.5 text-sm font-medium tracking-wide uppercase text-indigo-400 border border-indigo-500/30 rounded-full mb-8">
        {c.badge}
      </span>

      <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 tracking-tight leading-[1.1]">
        {c.headline}
      </h2>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed">
        {c.subtitle}
      </p>
    </div>

    <!-- Process Timeline -->
    <div class="relative max-w-5xl mx-auto mb-20">
      <!-- Horizontal connection line (desktop) -->
      <div class="hidden lg:block absolute top-[3.25rem] left-[12.5%] right-[12.5%] h-px bg-slate-700/60">
        <div class="absolute inset-0 animate-draw-line bg-gradient-to-r from-transparent via-indigo-500/60 to-transparent"></div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-6">
        {c.steps.map((step, index) => (
          <div class="step-card group relative text-center animate-on-scroll" style={`animation-delay: ${index * 120}ms`}>
            <!-- Step indicator -->
            <div class="relative inline-flex items-center justify-center mb-6">
              <div class="w-14 h-14 rounded-xl bg-slate-800 border border-slate-700 flex items-center justify-center group-hover:border-indigo-500/50 group-hover:bg-slate-800/80 transition-all duration-300">
                <Icon name={step.icon} size={24} class="text-indigo-400" />
              </div>
              <span class="absolute -top-1.5 -right-1.5 w-6 h-6 rounded-md bg-indigo-600 text-white text-xs font-bold flex items-center justify-center">
                {index + 1}
              </span>
            </div>

            <h3 class="font-display text-base font-bold text-white mb-2">{step.title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Stats row -->
    <div class="flex flex-wrap justify-center gap-12 md:gap-20 mb-14 animate-on-scroll">
      {c.stats.map((stat, index) => (
        <div class="text-center" style={`animation-delay: ${index * 80}ms`}>
          <div class="text-4xl md:text-5xl font-display font-bold text-white mb-1 tabular-nums">
            {stat.value}
          </div>
          <div class="text-sm text-slate-500 uppercase tracking-wider font-medium">{stat.label}</div>
        </div>
      ))}
    </div>

    <!-- Divider -->
    <div class="flex justify-center mb-10">
      <div class="w-12 h-px bg-slate-700"></div>
    </div>

    <!-- CTA - solid color, no gradient -->
    <div class="text-center animate-on-scroll">
      <a
        href={`/${lang}${c.ctaLink}`}
        class="group inline-flex items-center gap-3 px-8 py-4 bg-white text-slate-900 font-semibold rounded-xl hover:bg-slate-100 active:scale-[0.98] transition-all duration-200"
      >
        <span>{c.cta}</span>
        <Icon name="arrow-right" size={18} class="group-hover:translate-x-1 transition-transform duration-200" />
      </a>
    </div>
  </div>
</section>

<style>
  .step-card {
    padding: 1.5rem 0.75rem;
    border-radius: 0.75rem;
    transition: background-color 0.3s ease;
  }

  .step-card:hover {
    background-color: rgb(255 255 255 / 0.02);
  }
</style>
